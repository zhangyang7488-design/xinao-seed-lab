{
  "schema_version": "xinao.codex_to_grok_segment_audit_summon.v1",
  "sentinel": "SENTINEL:CODEX_TO_GROK_SEGMENT_AUDIT_SUMMON_V1",
  "binding": "user_authoritative_2026-06-28",
  "authoritative_chain_ref": "grok-admin-bridge/grok_user_authoritative_segment_audit_chain.v1.json",
  "title_cn": "段审环双向双投递（唯一口径见 authoritative_chain_ref）",
  "user_confirmed_flow_cn": "Codex 做完 → 后台 + Grok 桌面窗交审 → 有窗用窗、没窗新开 → Grok 自动审（用户代理）→ 不行回去改 / 行下一段 / 真完成才能停 → Grok 双投递 verdict 回 Codex",
  "replaces_old_rule_cn": "废止「只后台不交窗」「等用户喊审查」「有窗仍shortcut多开」",
  "segment_audit_loop": {
    "leg1_codex_to_grok": {
      "trigger": "segment_audit_ready=true on current task",
      "mode": "dual_visible_and_backend",
      "backend": "D:\\XINAO_CLEAN_RUNTIME\\state\\codex_to_grok_segment_audit_summon\\tasks\\{task_id}.json",
      "backend_latest": "D:\\XINAO_CLEAN_RUNTIME\\state\\codex_to_grok_segment_audit_summon\\latest.json",
      "visible": "Grok桌面窗口 typeahead + grok-admin-bridge/inbox/segment_audit_summon_visible.md",
      "visible_trace": "D:\\XINAO_CLEAN_RUNTIME\\state\\codex_to_grok_segment_audit_summon\\frontend_tui_send\\tasks\\{task_id}.json",
      "codex_script_target": "Send-CodexSegmentAuditSummonToGrokV2.ps1",
      "window_policy_cn": "有已开Grok窗复用；无则shortcut新开",
      "message_kind": "segment_audit_summon_not_user_intent",
      "forbidden": ["verdict", "pass", "fail", "completion_claim", "stop"]
    },
    "leg2_grok_to_codex": {
      "trigger": "Grok收到leg1后自动开审采证据并出判决",
      "order_cn": "先双投递 verdict 回 Codex，再对用户中文说明",
      "segment_verdict_auto_delivery": true,
      "exempt_from_parallel_audit_user_agreement": true,
      "mode": "dual_visible_and_backend",
      "backend": "/codex-a/intent",
      "visible": "Invoke-CodexAManagedVisibleInject.ps1 -Typeahead",
      "grok_script": "Send-GrokIntentToCodexA.ps1",
      "receive_script": "Receive-CodexSegmentAuditSummon.ps1",
      "message_kind": "grok_segment_verdict",
      "required_fields": ["grok_verdict", "verdict_delivery_mode=dual_visible_and_backend", "task_id"]
    }
  },
  "isolation_boundary_revised": {
    "still_forbidden": [
      "Codex writes grok-admin-bridge source except summon inbox + shared state read models",
      "Codex emits grok_verdict or user completion",
      "Codex modifies Grok session/rules/hooks",
      "Codex binds Grok ingress into A execution lock"
    ],
    "explicitly_allowed_in_segment_audit_loop": [
      "Codex dual_deliver segment_audit_summon to Grok desktop + D state",
      "Grok Receive-CodexSegmentAuditSummon.ps1 ingest and auto audit",
      "Grok dual_deliver verdict back to Codex"
    ]
  },
  "cross_verify": {
    "leg1": [
      "action_delivery_trace task_id",
      "frontend_tui_sent=true",
      "used_existing_grok_tui or shortcut_launched_when_none"
    ],
    "leg2": [
      "codexa_managed_visible_inject session_modified_after_send",
      "grok_l1_l2_segment_gate dual_visible"
    ]
  },
  "not_user_completion": true,
  "not_codex_as_grok_proxy": true
}