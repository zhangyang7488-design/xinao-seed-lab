  "governance_loop_steps": [
    {
      "id": "0_classify",
      "name_cn": "归类",
      "must_output": "task_class",
      "classes": ["platform_ops", "business_wave", "delivery_shell", "dialogue_only", "research_external"]
    },
    {
      "id": "1_external_first",
      "name_cn": "外部成熟先行",
      "must_output": "external_refs[]",
      "rules_cn": [
        "平台/运维/架构：WebSearch/WebFetch 官方文档与官方仓库优先",
        "用户明示外部成熟或治理环触发时：禁止用本地rg/盘点冒充调研",
        "产出 prior_art 一句：业界已有 A/B，拟采纳谁"
      ]
    },
    {
      "id": "2_local_inventory",
      "name_cn": "本地资产清单",
      "must_output": "local_refs[]",
      "rules_cn": [
        "E:\\XINAO_EXTERNAL_MATURE、S 脚本、seam_map 仅作已有资产目录",
        "不得把 on_disk 当 deployed truth"
      ]
    },
    {
      "id": "3_choose_carrier",
      "name_cn": "选最大成熟载体",
      "must_output": "carrier_choice",
      "rules_cn": [
        "一次集成截面：Compose/Cloud/官方Plugin/官方Worker部署",
        "禁止默认：平行orchestrator、隐藏Start-Process守护、N个ps1补丁"
      ]
    },
    {
      "id": "4_plan_artifact",
      "name_cn": "迷你ADR规划",
      "must_output": "plan_ref",
      "rules_cn": [
        "写清：采纳谁、薄绑什么、证据路径、明确不建什么",
        "用户喊先规划/plan only：本步为硬停点，禁止写实施"
      ]
    },
    {
      "id": "5_deviation_gate",
      "name_cn": "偏离门",
      "must_output": "deviation_or_none",
      "rules_cn": [
        "必须手搓时登记 deviation：原因、范围、日落、不得升级默认主路",
        "OPA式策略门：见 grok_mature_first_policy.v1.json"
      ]
    },
    {
      "id": "6_execute",
      "name_cn": "实施",
      "must_output": "invoke_evidence[]",
      "precondition": "steps_0_to_5_recorded_or_plan_only_mode"
    },
    {
      "id": "7_evidence_lens",
      "name_cn": "证据与透镜",
      "must_output": "readback_three_cn",
      "ref": "grok_meta_cognition_lens.v1.json"
    }
  ],
  "user_trigger_phrases_cn": {
