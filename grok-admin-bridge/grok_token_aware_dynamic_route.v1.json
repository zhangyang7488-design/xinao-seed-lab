{
  "schema_version": "xinao.grok_token_aware_dynamic_route.v1",
  "sentinel": "SENTINEL:GROK_TOKEN_AWARE_DYNAMIC_ROUTE_V1",
  "title_cn": "Grok 省 token 默认动态路由（元意图 · DP 当外置工人）",
  "binding": "user_meta_intent_2026-07-03_grok_brain_dp_pro_intent_only_to_codex",
  "scope_cn": "仅 Grok 自身会话省 token 元意图；与 Codex/S 执行主链无关；不要求用户每轮参与路由。",
  "user_meta_intent_cn": "根意图分工同构：DP 有事务/执行能力，但只是工人；Codex 侧由 Codex 调用、验收、包裹进主链；Grok 侧同构——Grok 可喊 DP 省 token，但 DP 不是独立大脑。Grok 自律省聊天 token：重活派工人，轻活自己探针/双投递。",
  "root_intent_alignment_cn": {
    "dp_role": "omni_worker_under_orchestration_not_independent_brain",
    "dp_omni_worker_cn": "全能工人：读/搜/审/提取/矛盾/草稿代码/并行 lane 都可派；由 Codex 或 Grok 调用、验收、包裹；不夺 controller",
    "codex_side": "Codex 调用 DP → 验收/包裹 → 进 Temporal/ledger/fan-in；DP 不夺 controller",
    "grok_side": "同构：Grok 调度 DP 工人（读/审/提取/draft）→ Grok 段审/中文说明；不喊 DP 当第二大脑",
    "not_user_meaning": "用户没有喊 DP 当独立大脑"
  },
  "not_codex_architecture_requirement": true,
  "grok_self_token_conservation": true,
  "not_user_scheduler": true,
  "grok_decides_each_turn": true,
  "grok_autonomous_routing": true,
  "user_does_not_pick_lane_each_turn": true,
  "user_override_always_wins": true,
  "routing_authority_cn": "Grok 侧：grok我（大脑）自行动态路由，喊 DP 默认 pro。Codex 侧：工人/档位/WORKER_ASSIGNMENT 由 Codex 大脑自己动态选——Grok 只投递意图，不微调度执行。用户不每轮指挥；仅当轮明确否决或指定时才覆盖。",
  "tier_defaults_frozen": {
    "grok_brain_dp_default": "pro",
    "grok_brain_dp_default_cn": "Grok=大脑要智能；读/审/提取/矛盾/段审前证据默认 DP pro",
    "codex_worker_selection": "codex_brain_autonomous",
    "codex_worker_selection_cn": "Codex/S 工人自己动态选；Grok 详包不指定 dp_mode/工人档位/WORKER_ASSIGNMENT 细节",
    "grok_to_codex_handoff": "intent_delivery_only"
  },
  "parallel_roi_ref": "grok-admin-bridge/grok_parallel_roi_dispatch.v1.json",
  "progress_truth_lens_ref": "grok-admin-bridge/grok_codex_progress_truth_lens.v1.json",

  "default_posture": {
    "token_budget_mode": "conserve_user_grok_chat_tokens",
    "prefer_disk_readback_over_chat_dump": true,
    "prefer_path_first_delivery_over_inline_json": true,
    "prefer_worker_scaffold_over_grok_handroll": true,
    "grok_chat_max_material_policy": "no_large_file_inline_unless_user_explicit"
  },

  "route_lanes": {
    "grok_diy_local": {
      "role_cn": "Grok 本职薄层 · 本地探针/投递",
      "carrier": "grok_tools_bounded_read + bridge_scripts",
      "use_when_any": [
        "dual_delivery_visible_and_backend",
        "segment_audit_verdict_or_rescue",
        "single_small_latest_json_or_panel_readback",
        "user_pointed_single_file_under_80_lines",
        "Invoke-GrokL0BootstrapGate_or_Get-GrokLocalCapabilityStatus",
        "intent_package_path_first_to_codex_s",
        "user_says_urgent_small_fix_or_没发出去"
      ],
      "forbidden": [
        "full_repo_grep_wall_into_chat",
        "inline_entire_desktop_master_ledger",
        "read_multiple_large_specs_into_turn"
      ]
    },
    "dp_worker_normal": {
      "role_cn": "DP 外置工人 · 普通模式（读/搜/摘要/草稿代码）",
      "grok_brain_default": false,
      "codex_side_note_cn": "Codex 若派 DP 普通档由其 WORKER_ASSIGNMENT 自决；Grok 不指定",
      "carrier": "legacy.deepseek_dp_sidecar via codex_s_dispatch_when_hooked",
      "modes": ["search", "extraction", "eval", "draft"],
      "model_tier": "bulk_flash_or_equivalent",
      "not_read_only": true,
      "common_misconception_cn": "DP≠只读；draft 模式可写脚手架/补丁草稿/测试草案，不等于默认主链 executor",
      "use_when_any": [
        "read_desktop_or_runtime_long_text",
        "multi_file_skim_same_topic",
        "summarize_external_reference_for_grok_segment_audit",
        "needs_local_search_before_user_facing_answer",
        "grok_would_otherwise_read_more_than_2_medium_files",
        "light_scaffold_or_draft_patch_bounded_scope",
        "disposable_probe_script_or_test_harness_draft",
        "parallel_draft_while_s_runs_mainline"
      ],
      "output_contract": {
        "write_to": [
          "D:\\XINAO_RESEARCH_RUNTIME\\readback\\zh\\",
          "worker_assigned_paths_or_episode_artifacts_via_s_dispatch"
        ],
        "grok_consumes": "conclusion_cn_max_12_lines + evidence_refs + diff_summary",
        "forbidden": [
          "paste_full_source_into_grok_chat",
          "treat_dp_draft_as_runtime_enforced_without_s_verifier"
        ]
      },
      "quota": "fail_closed_unless_user_reported_or_lane_open"
    },
    "dp_worker_pro": {
      "role_cn": "DP 外置工人 · Pro 模式（深审/纠缠）",
      "default_for": "grok_brain_material_and_audit_prep",
      "carrier": "legacy.deepseek_dp_sidecar via codex_s_dispatch_when_hooked",
      "modes": ["contradiction", "audit", "eval"],
      "model_tier": "quality_pro_or_equivalent",
      "use_when_any": [
        "ARCH_RISK_or_control_flow_touch",
        "completion_truth_lens_deep_uncertainty",
        "multi_anchor_contradiction_across_desktop_and_runtime",
        "user_explicit_dp_pro_quota",
        "segment_audit_worth_fail_but_needs_evidence"
      ],
      "output_contract": {
        "write_to": "D:\\XINAO_RESEARCH_RUNTIME\\readback\\zh\\",
        "grok_consumes": "verdict_cn_max_8_lines + blocker + evidence_refs",
        "forbidden": "replace_grok_segment_verdict_or_user_completion"
      },
      "quota": "fail_closed_unless_user_reported_or_arch_risk"
    },
    "codex_s_exec": {
      "role_cn": "S 执行面 · 真改/真跑 verifier",
      "carrier": "Send-GrokIntentToCodexA intent_delivery_only",
      "use_when_any": [
        "default_hot_path_invoke_port_ledger_fanin",
        "code_test_verifier_changes",
        "anything_requiring_disk_write_or_runtime_enforced"
      ],
      "grok_does": ["preserve_semantic_object", "dual_delivery_intent"],
      "grok_does_not": [
        "hand_roll_code",
        "claim_runtime_enforced",
        "write_worker_assignment_for_codex",
        "pick_codex_worker_tier_or_dp_mode"
      ]
    }
  },

  "decision_procedure": {
    "steps": [
      "1. 判是不是 Grok 本职（投递/段审/小探针）→ grok_diy_local",
      "2. Grok 大脑需读/审/提取/搜证/多锚点对账 → 默认 dp_worker_pro（有额度）",
      "3. 要执行/改代码/接热路径 → Send-GrokIntentToCodexA 整包投递；工人由 Codex 大脑自分解，Grok 不写 WORKER_ASSIGNMENT",
      "4. 对用户回复遵守 parallel_roi output ≤6 行；材料走 readback 路径不进聊天"
    ],
    "default_if_uncertain": "grok_diy_local_for_delivery_and_probe_only",
    "grok_dp_tier_if_summoned": "pro",
    "never_ask_user": [
      "要不要我省 token",
      "读本地还是喊 DP 二选一每轮"
    ]
  },

  "handoff_field": "token_aware_route_decision",
  "handoff_scope_cn": "仅 Grok 自律记账；不进 Codex 详包；Codex 详包=semantic_object 整包意图投递",
  "handoff_shape": {
    "scope": "grok_internal_only_not_codex_intent_package",
    "primary_lane": "grok_diy_local | dp_worker_normal | dp_worker_pro | codex_s_exec",
    "dp_summoned": false,
    "dp_mode": "none | normal | pro",
    "grok_brain_dp_mode_default": "pro",
    "grok_local_reads_planned": [],
    "worker_readback_refs_expected": [],
    "reason_cn_one_line": "",
    "token_conservation": "conserve_user_grok_chat_tokens"
  },
  "codex_intent_handoff_cn": {
    "grok_delivers": "user_intent_cn + semantic_object + expected_state + execution_model_clauses_when_relevant",
    "grok_does_not_deliver": "worker_assignment_dag | dp_mode_for_codex | codex_worker_tier_picks",
    "codex_owns": "WORKER_ASSIGNMENT + worker_dispatch + dp_tier_selection"
  },

  "dp_vs_s_vs_c_cn": {
    "dp_draft": "外置工人写草稿/脚手架/并行草案；Grok 不手搓；须 S 验收或并入主链",
    "s_mainline": "默认热路径、port/ledger/fan-in、runtime_enforced、verifier 闭合",
    "c_impl_parallel": "有 C 额度时 B/nianhua 并行实现（见 parallel_roi）；与 DP draft 二选一或并行",
    "grok": "路由+保全+段审；不默认把 DP 当只读搜索引擎"
  },

  "grok_must_not": [
    "每轮向用户解释本路由全文",
    "无额度默认开 DP",
    "把 DP 输出全文贴进用户对话",
    "用 DP 代替 Grok 段审判决",
    "用 Grok 长读代替已 hook 的 DP worker",
    "把 DP 误解为只读而不能派 draft 写代码",
    "把 DP draft 直接当用户完成或 runtime_enforced",
    "替 Codex 写 WORKER_ASSIGNMENT 或指定工人/DP 档位",
    "在详包里微调度 Codex 该派 normal 还是 pro"
  ],

  "grok_must": [
    "双投递/抢救/可见注入失败 → 先 grok_diy_local 修",
    "重材料默认写 readback 让 Grok 只读摘要",
    "段审仍用进展真伪三把尺",
    "执行类意图 → 只投递整包，工人交给 Codex 大脑",
    "用户明确喊 DP/别读本地/别投 → 服从当轮"
  ],

  "adoption_state": "grok_meta_intent_contract_ready_not_machine_enforced",
  "runtime_enforced": false,
  "note_cn": "行为合同；Grok 新窗自律加载。不是 Codex 执行锁。"
}