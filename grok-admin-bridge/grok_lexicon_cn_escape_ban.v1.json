{
  "schema_version": "xinao.grok_language_policy.v2",
  "sentinel": "SENTINEL:GROK_LANGUAGE_POLICY_V2",
  "status": "active",
  "default_user_language": "zh-CN",
  "keep_original": [
    "software names",
    "model names",
    "API fields",
    "file paths",
    "hashes"
  ],
  "avoid": [
    "unexplained jargon",
    "claim without evidence",
    "translation that changes object identity"
  ]
}
