{
  "schema_version": "xinao.grok_parallel_roi_dispatch.v1",
  "sentinel": "SENTINEL:GROK_PARALLEL_ROI_DISPATCH_V1",
  "binding": "user_2026-06-29_parallel_meta_cognition",
  "title_cn": "并行收益调度元认知（Grok 合同语义 · 非每轮长篇解释）",
  "purpose_cn": "用户问「要不要并行/多线程/开几路」或实时报额度时，Grok 按本合同出短决策；不指望 A 自动算 ROI；不对用户堆无关架构解释。",
  "not_per_message_essay": true,
  "grok_is_scheduler": true,
  "a_executes_only": true,
  "division_ref": "grok-admin-bridge/grok_parallel_audit_division.v1.json",
  "parallel_audit_ref": "grok-admin-bridge/parallel_global_audit_auditors.json",
  "handoff_field": "parallel_dispatch_decision",

  "user_trigger_phrases_cn": [
    "要不要并行",
    "并行多线程",
    "多线程",
    "开几路",
    "并行最大化",
    "收益调度",
    "额度怎么烧",
    "谁有额度",
    "C有额度",
    "DP有额度",
    "B没额度",
    "Spark没了",
    "并行审计",
    "并行实现",
    "开子代理吗",
    "开 subagent 吗"
  ],
  "user_intent_decode_cn": "以上任一 ≈ 用户在问：当前任务下，并行开什么最划算；并可能附带实时额度快照。不是问架构课，不是要 Grok 解释合同全文。",

  "quota_snapshot_input": {
    "source_priority": [
      "user_explicit_this_turn",
      "conversation_recent_quota_report",
      "bridge.config.json quota_roles_hint_only"
    ],
    "user_report_patterns_cn": [
      "当前有 C 和 DP",
      "C有 DP有 B没",
      "只有 A",
      "Spark 尽了",
      "DP 还没烧"
    ],
    "lanes": {
      "A_exec": { "role_cn": "主实现 / harness / Temporal 续跑焊", "carrier": "codex_exec_json", "default": "always_if_mainline_open" },
      "A_subagent": { "role_cn": "只读帮眼预审", "carrier": "official_subagent", "default": "off", "max_parallel": 1 },
      "B_spark": { "role_cn": "轻实现或工程审计", "carrier": "codex_sdk_worker | codex_exec_json_background", "default": "if_quota_available" },
      "C_impl": { "role_cn": "并行写 B/nianhua（实现或测试）", "carrier": "codex_exec_json", "workspace": "B/nianhua", "codex_home": ".codex-c", "default": "if_quota_and_impl_volume" },
      "C_audit": { "role_cn": "只读工程审计（B 缺席时）", "carrier": "codex_exec_json_background", "default": "if_b_unavailable" },
      "DP_audit": { "role_cn": "语义/控制流/假完成审计", "carrier": "litellm_deepseek_gateway_background", "default": "if_quota_and_uncertainty" }
    },
    "absent_means": "用户未报某 lane → 视为 unknown，该 lane 不默认开（fail-closed on spend）"
  },

  "blocker_taxonomy": {
    "SCHEDULE_STUCK": {
      "signals_cn": ["干完不接下一棒", "auto_continue 空", "A 前台等", "next_ready 真但无 worker", "correction_note 救场"],
      "open": ["A_exec"],
      "optional_if_quota": ["C_impl"],
      "avoid": ["A_subagent", "DP_audit", "C_audit", "B_audit"],
      "reason_cn": "卡调度；烧审计/帮眼不加速主链"
    },
    "IMPL_VOLUME": {
      "signals_cn": ["多文件实改", "测试+规格+代码同时要", "单 worker 吞吐不够"],
      "open": ["A_exec", "C_impl"],
      "optional_if_quota": ["DP_audit"],
      "avoid": ["A_subagent_x3", "duplicate_audit_stack"],
      "reason_cn": "实现并行 ROI 最高"
    },
    "ARCH_RISK": {
      "signals_cn": ["动 harness/ingress/DAG/控制流", "怕改坏续跑", "大重构"],
      "open": ["A_exec", "C_impl"],
      "optional_if_quota": ["DP_audit", "A_subagent_x1"],
      "avoid": ["B_audit_if_spark_empty", "triple_audit"],
      "reason_cn": "实现并行 + 最多一路深审计 + 可选 1 帮眼"
    },
    "IDLE_SPIN": {
      "signals_cn": ["空转", "只数 worker", "无 diff", "纯观测"],
      "open": [],
      "optional_if_quota": [],
      "avoid": ["all_parallel"],
      "reason_cn": "先修卡点，不开并行装饰"
    }
  },

  "roi_decision_procedure": {
    "steps": [
      "1. 识别用户是否在触发 parallel_roi 意图（trigger_phrases）",
      "2. 合并用户当轮额度快照（quota_snapshot_input）",
      "3. 判 blocker_taxonomy（以当前主链证据为准，一项即可）",
      "4. 对 open/optional/avoid 与额度做交集：有额度才开 optional；avoid 硬禁",
      "5. 应用 parallel_caps 截断",
      "6. 输出 parallel_dispatch_decision + 对用户 ≤6 行中文"
    ],
    "default_blocker_if_unknown": "SCHEDULE_STUCK",
    "prefer_impl_over_audit_when_both_quota": true,
    "prefer_C_impl_over_C_audit_when_C_quota": true,
    "dp_burn_when": ["ARCH_RISK", "IMPL_VOLUME_with_control_flow_touch", "user_explicit_DP_quota"]
  },

  "parallel_caps": {
    "impl_lanes_max": 2,
    "impl_lanes_allowed": ["A_exec", "C_impl"],
    "audit_lanes_max": 1,
    "audit_lanes_pick_one": ["DP_audit", "C_audit", "B_spark_audit_readonly"],
    "subagent_max": 1,
    "subagent_default": 0,
    "forbid_full_audit_stack": ["B", "C_audit", "DP", "A_subagent_x3"]
  },

  "output_contract": {
    "to_user_max_lines": 6,
    "required_sections_cn": ["开", "不开", "理由一句", "下一条机器动作"],
    "forbidden_to_user": [
      "长架构复述",
      "合同全文解释",
      "未问及的 5d33 历史",
      "宣布完成",
      "替 A 声称已派工"
    ],
    "handoff_parallel_dispatch_decision_shape": {
      "blocker": "SCHEDULE_STUCK | IMPL_VOLUME | ARCH_RISK | IDLE_SPIN",
      "quota_reported": { "A_exec": "unknown|yes|no", "C": "unknown|yes|no", "DP": "unknown|yes|no", "B_spark": "unknown|yes|no" },
      "open_lanes": [],
      "avoid_lanes": [],
      "subagent_count": 0,
      "summon_parallel_audit": [],
      "reason_cn": "一句",
      "next_machine_action_cn": "一句"
    }
  },

  "invoke_scripts": {
    "parallel_audit": "grok-admin-bridge/Invoke-GrokParallelGlobalAudit.ps1",
    "parallel_audit_status": "grok-admin-bridge/Get-GrokParallelGlobalAuditStatus.ps1",
    "intent_delivery": "grok-admin-bridge/Send-GrokIntentToCodexA.ps1",
    "note_cn": "Grok 定决策；审计用 Invoke；实现并行写进详包 WORKER_ASSIGNMENT 由 A 派"
  },

  "example_user_turn": {
    "user": "要不要并行多线程？当前有 C 和 DP 额度",
    "grok_response_shape_cn": "开：A 主改 + C 并行写 B 仓测试。不开：子代理、B。DP：后台语义审计（动控制流时）。下一条：详包带 Lane-C + 可选 Summon DP。"
  },

  "a_must_not": [
    "自行砍掉 Grok parallel_dispatch_decision 中的 C_impl/DP_audit 且无 blocker 证据",
    "默认满开 3 subagent",
    "用 subagent 代替 exec 修 SCHEDULE_STUCK"
  ],

  "grok_must_not": [
    "每轮重复本合同全文",
    "无额度报告时默认开 B/C/DP",
    "用并行审计冒充实现并行",
    "用户只问决策时写千字背景"
  ]
}