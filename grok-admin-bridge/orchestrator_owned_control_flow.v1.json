{
  "schema_version": "xinao.orchestrator_owned_control_flow.spec.v1",
  "sentinel": "SENTINEL:XINAO_ORCHESTRATOR_OWNED_CONTROL_FLOW_V1",
  "scope": "5d33 wave2 harness weld: Temporal owns continuation control flow; A foreground 180s watching is rescue only.",
  "authority_boundary": {
    "not_source_of_truth": true,
    "not_user_completion": true,
    "not_completion_decision": true,
    "not_execution_controller": true,
    "truth_carriers": [
      "Temporal Event History",
      "same-workflow continue_same_task signal",
      "task-bound codex exec --json JSONL/result evidence",
      "OPA/Conftest policy readback",
      "observation-snapshot read model"
    ]
  },
  "legal_stop_states": [
    "completion_claim_allowed_and_stop_allowed",
    "named_blocker_with_no_next_ready_and_no_pending_activity",
    "phase_exit_waiting_grok_segment_audit"
  ],
  "illegal_stop_states": [
    "worker_terminal_next_ready_no_enqueue",
    "worker_pass_clears_assignment_frontier",
    "latest_json_or_panel_used_as_progress_truth",
    "idle_handoff_used_while_assignment_next_ready_true",
    "grok_wait_used_as_l1_continuation_gate"
  ],
  "required_post_worker_closeout": {
    "worker_exit_is_not_workflow_exit": true,
    "if_assignment_dag_next_ready_true": [
      "prepare or enqueue same-workflow auto_continue signal",
      "preserve next_ready frontier",
      "write ORCHESTRATOR_* named_blocker when enqueue cannot be proven"
    ],
    "if_node_consumed": [
      "advance next_ready to the next non-terminal node",
      "or write phase-boundary named_blocker"
    ]
  },
  "dedup_policy": {
    "same_next_ready_node_unconsumed": "redispatch_unconsumed_next_ready",
    "same_next_ready_node_consumed": "suppress_duplicate",
    "silent_empty_signal_for_unconsumed_node_allowed": false
  },
  "default_routes": {
    "continuation_owner": "CodexA brain + Temporal assignment DAG",
    "worker_carrier": "codex exec --json task-bound worker",
    "human_exit": "Grok Chinese side channel; raw pytest/PASS wall stays backend-only",
    "idle_handoff": "fallback_only_rank_3_when_no_next_ready"
  },
  "verification": [
    "python -m unittest tests.test_temporal_codex_task_workflow",
    "python -m unittest tests.test_ingress_result_recovery",
    "GET /codex-a/observation-snapshot exposes orchestrator_control_flow",
    "task-bound JSONL/result evidence remains under the same task_id/workflow_id"
  ]
}
