{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_allocation_plan.v1.json",
  "title": "Codex S AllocationPlan",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "work_id",
    "route_profile",
    "task_id",
    "wave_id",
    "status",
    "not_task_route_decision_enum",
    "same_task_multi_lane_allocation",
    "feedback_inputs",
    "lane_allocations",
    "worker_brief_queue",
    "dispatch_attempts",
    "repair_plan",
    "stop_allowed",
    "next_allocation_advice",
    "target_width_source",
    "fixed_target_width_used",
    "fixed_20_or_50_used",
    "report_substitute_allowed",
    "completion_claim_allowed",
    "not_source_of_truth",
    "not_user_completion",
    "not_completion_decision",
    "not_completion_gate",
    "not_execution_controller",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.allocation_plan.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_CODEX_S_ALLOCATION_PLAN_V1"
    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "route_profile": {
      "const": "seed_cortex_phase0"
    },
    "status": {
      "enum": [
        "allocation_plan_ready",
        "allocation_plan_validation_blocked"
      ]
    },
    "not_task_route_decision_enum": {
      "const": true
    },
    "same_task_multi_lane_allocation": {
      "const": true
    },
    "target_width_source": {
      "const": "derived_from_runtime_feedback_inputs"
    },
    "fixed_target_width_used": {
      "const": false
    },
    "fixed_20_or_50_used": {
      "const": false
    },
    "lane_allocations": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "lane_id",
          "lane_class",
          "objective",
          "provider_candidates",
          "requested_width",
          "dependencies",
          "queue",
          "expected_artifact",
          "dispatch_attempts",
          "worker_output_must_enter_staging",
          "direct_final_allowed",
          "completion_claim_allowed",
          "not_execution_controller"
        ],
        "properties": {
          "lane_class": {
            "enum": [
              "foreground_brain",
              "cheap_draft",
              "extraction",
              "eval",
              "contradiction",
              "audit",
              "search_source",
              "ci_verify",
              "repo_exec",
              "merge_accept",
              "approval_gate",
              "repair",
              "durable_temporal"
            ]
          },
          "requested_width": {
            "type": "integer",
            "minimum": 0
          },
          "provider_candidates": {
            "type": "array",
            "minItems": 1
          },
          "direct_final_allowed": {
            "const": false
          },
          "completion_claim_allowed": {
            "const": false
          },
          "not_execution_controller": {
            "const": true
          }
        }
      },
      "contains": {
        "type": "object",
        "properties": {
          "lane_class": {
            "const": "cheap_draft"
          }
        },
        "required": [
          "lane_class"
        ]
      }
    },
    "worker_brief_queue": {
      "type": "object",
      "required": [
        "schema_version",
        "brief_count",
        "briefs",
        "completion_claim_allowed",
        "not_execution_controller"
      ],
      "properties": {
        "schema_version": {
          "const": "xinao.codex_s.worker_brief_queue.v1"
        },
        "brief_count": {
          "type": "integer",
          "minimum": 3
        },
        "completion_claim_allowed": {
          "const": false
        },
        "not_execution_controller": {
          "const": true
        }
      }
    },
    "dispatch_attempts": {
      "type": "object",
      "required": [
        "dispatch_attempt_count",
        "attempts",
        "report_substitute_allowed",
        "completion_claim_allowed",
        "not_execution_controller"
      ],
      "properties": {
        "dispatch_attempt_count": {
          "type": "integer",
          "minimum": 3
        },
        "report_substitute_allowed": {
          "const": false
        },
        "completion_claim_allowed": {
          "const": false
        },
        "not_execution_controller": {
          "const": true
        }
      }
    },
    "repair_plan": {
      "type": "object",
      "required": [
        "dispatch_to",
        "temporal_consumable",
        "report_substitute_allowed",
        "completion_claim_allowed",
        "not_execution_controller"
      ],
      "properties": {
        "dispatch_to": {
          "const": "root_intent_loop_driver"
        },
        "temporal_consumable": {
          "const": true
        },
        "report_substitute_allowed": {
          "const": false
        },
        "completion_claim_allowed": {
          "const": false
        },
        "not_execution_controller": {
          "const": true
        }
      }
    },
    "stop_allowed": {
      "type": "object",
      "required": [
        "derived_only",
        "value",
        "requires_empty"
      ],
      "properties": {
        "derived_only": {
          "const": true
        }
      }
    },
    "report_substitute_allowed": {
      "const": false
    },
    "completion_claim_allowed": {
      "const": false
    },
    "not_source_of_truth": {
      "const": true
    },
    "not_user_completion": {
      "const": true
    },
    "not_completion_decision": {
      "const": true
    },
    "not_completion_gate": {
      "const": true
    },
    "not_execution_controller": {
      "const": true
    },
    "validation": {
      "type": "object",
      "required": [
        "passed",
        "checks"
      ],
      "properties": {
        "passed": {
          "const": true
        }
      }
    }
  }
}
