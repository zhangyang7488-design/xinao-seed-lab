    "stage_order",
    "source_entry",
    "user_latest_correction_digest",
    "foreground_brain_decision",
    "must_do_10",
    "wave_steps_8",
    "target_width",
    "actual_dispatched_width",
    "actual_completed_width",
    "mode_counts",
    "draft_count",
    "true_dp_draft_count",
    "local_stub_draft_count",
    "eval_count",
    "audit_count",
    "staged_count",
    "merged_count",
    "spend_entry_count",
    "provider_tier_usage",
    "token_cost_spend",
