{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_modular_dynamic_worker_pool_phase1.v1.json",
  "title": "Codex S Modular Dynamic Worker Pool Phase1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "work_id",
    "route_profile",
    "task_id",
    "wave_id",
    "status",
    "stage_order",
    "source_entry",
    "user_latest_correction_digest",
    "foreground_brain_decision",
    "must_do_10",
    "wave_steps_8",
    "target_width",
    "actual_dispatched_width",
    "actual_completed_width",
    "progress_counts",
    "worker_dispatch_ledger",
    "worker_dispatch_ledger_ref",
    "worker_dispatch_ledger_succeeded_count",
    "worker_dispatch_ledger_succeeded_matches_completed",
    "runtime_enforced_requested",
    "runtime_enforcement_truth_chain",
    "python_carrier",
    "mode_counts",
    "draft_count",
    "true_dp_draft_count",
    "qwen_prepaid_draft_count",
    "external_cheap_draft_count",
    "local_stub_draft_count",
    "qwen_prepaid_cheap_worker_ready",
    "qwen_first_applies_only_to",
    "qwen_first_must_not_override",
    "qwen_prepaid_usage",
    "qwen_prepaid_first_required_count",
    "qwen_prepaid_first_attempted_count",
    "qwen_prepaid_first_succeeded_count",
    "qwen_fallback_allowed_count",
    "eval_count",
    "audit_count",
    "staged_count",
    "merged_count",
    "spend_entry_count",
    "provider_tier_usage",
    "token_cost_spend",
    "rate_limit_error",
    "named_blocker",
    "provider_schemas",
    "provider_schema_refs",
    "worker_assignment",
    "worker_briefs",
    "worker_brief_queue",
    "dynamic_width_policy",
    "draft_staging_queue",
    "merge_consumer",
    "spend_ledger",
    "width_blocker",
    "trigger_binding",
    "parallel_draft_batch_refs",
    "default_route_binding",
    "artifact_acceptance_queue",
    "watchdog_downgrade",
    "can_invoke_now",
    "evidence_refs",
    "readback_refs",
    "validation",
    "completion_claim_allowed",
    "not_source_of_truth",
    "not_user_completion",
    "not_completion_decision",
    "not_execution_controller"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "contract_kind": { "const": "control_plane_repair" }
        },
        "required": ["contract_kind"]
      },
      "then": {
        "properties": {
          "control_plane_repair_mode": { "const": true },
          "target_width": { "minimum": 1 },
          "actual_dispatched_width": { "minimum": 1 },
          "actual_completed_width": { "minimum": 1 },
          "mode_counts": {
            "properties": {
              "draft": { "minimum": 0 }
            }
          },
          "draft_count": { "minimum": 0 },
          "staged_count": { "minimum": 0 },
          "merged_count": { "minimum": 0 },
          "eval_count": { "minimum": 0 },
          "spend_entry_count": { "minimum": 1 },
          "trigger_binding": {
            "properties": {
              "status": { "const": "control_plane_repair_hot_path_bound" },
              "hot_path": { "const": "detect_blocker->repair_lanes->fan_in_repair_evidence->resume" }
            }
          }
        }
      },
      "else": {
        "properties": {
          "target_width": { "minimum": 3 },
          "actual_dispatched_width": { "minimum": 3 },
          "actual_completed_width": { "minimum": 3 },
          "mode_counts": {
            "properties": {
              "draft": { "minimum": 1 }
            }
          },
          "draft_count": { "minimum": 1 },
          "staged_count": { "minimum": 1 },
          "merged_count": { "minimum": 1 },
          "eval_count": { "minimum": 1 },
          "spend_entry_count": { "minimum": 3 },
          "trigger_binding": {
            "properties": {
              "status": { "const": "parallel_draft_to_merge_hot_path_bound" },
              "hot_path": { "const": "parallel_draft->merge->writer" }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.modular_dynamic_worker_pool_phase1.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_CODEX_S_MODULAR_DYNAMIC_WORKER_POOL_PHASE1"
    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "route_profile": {
      "const": "seed_cortex_phase0"
    },
    "task_id": {
      "const": "modular_dynamic_worker_pool_phase1_20260704"
    },
    "status": {
      "enum": [
        "modular_dynamic_worker_pool_phase1_wave_merged",
        "modular_dynamic_worker_pool_phase1_wave_blocked"
      ]
    },
    "contract_kind": {
      "enum": ["parallel_draft_pool", "control_plane_repair"]
    },
    "control_plane_repair_mode": {
      "type": "boolean"
    },
    "stage_order": {
      "type": "array",
      "prefixItems": [
        { "const": "parallel_draft" },
        { "const": "merge" },
        { "const": "writer" }
      ]
    },
    "source_entry": {
      "type": "object",
      "required": [
        "source_entry_root",
        "source_entry_read_at",
        "sampled_count",
        "sampled_files",
        "source_entry_digest_sha256"
      ]
    },
    "user_latest_correction_digest": {
      "type": "object",
      "required": ["task_id", "sha256"]
    },
    "foreground_brain_decision": {
      "type": "object",
      "required": [
        "source_entry_read_at",
        "user_latest_correction_digest",
        "333_alignment",
        "current_frontier",
        "worker_briefs_generated",
        "why_this_width",
        "draft_artifacts_consumed",
        "merge_decision",
        "next_wave_decision",
        "blocker_or_continue_reason"
      ]
    },
    "must_do_10": {
      "type": "array",
      "minItems": 10
    },
    "wave_steps_8": {
      "type": "array",
      "minItems": 8
    },
    "target_width": {
      "type": "integer",
      "minimum": 1
    },
    "actual_dispatched_width": {
      "type": "integer",
      "minimum": 1
    },
    "actual_completed_width": {
      "type": "integer",
      "minimum": 1
    },
    "progress_counts": {
      "type": "object",
      "required": ["planned", "dispatched", "completed", "accepted", "planned_is_progress"],
      "properties": {
        "planned_is_progress": { "const": false }
      }
    },
    "worker_dispatch_ledger": {
      "type": "object",
      "required": ["schema_version", "succeeded_count", "phase1_binding"],
      "properties": {
        "schema_version": { "const": "xinao.codex_s.worker_dispatch_ledger.v1" }
      }
    },
    "worker_dispatch_ledger_ref": {
      "type": "string",
      "minLength": 1
    },
    "worker_dispatch_ledger_succeeded_count": {
      "type": "integer",
      "minimum": 0
    },
    "worker_dispatch_ledger_succeeded_matches_completed": {
      "const": true
    },
    "runtime_enforced_requested": {
      "type": "boolean"
    },
    "runtime_enforced_blocker": {
      "type": "string"
    },
    "runtime_enforcement_truth_chain": {
      "type": "object",
      "required": ["ready", "checks"],
      "properties": {
        "ready": { "type": "boolean" },
        "checks": { "type": "object" }
      }
    },
    "python_carrier": {
      "type": "object",
      "required": [
        "expected_python",
        "current_python",
        "expected_python_exists",
        "using_expected_python",
        "provider_readiness_fact_allowed"
      ]
    },
    "mode_counts": {
      "type": "object",
      "required": [
        "draft",
        "eval",
        "contradiction",
        "audit",
        "extraction",
        "citation_verify",
        "search",
        "provider_probe"
      ],
      "properties": {
        "draft": { "type": "integer", "minimum": 0 },
        "search": { "const": 0 },
        "provider_probe": { "const": 0 }
      }
    },
    "draft_count": {
      "type": "integer",
      "minimum": 0
    },
    "staged_count": {
      "type": "integer",
      "minimum": 0
    },
    "true_dp_draft_count": {
      "type": "integer",
      "minimum": 0
    },
    "qwen_prepaid_draft_count": {
      "type": "integer",
      "minimum": 0
    },
    "external_cheap_draft_count": {
      "type": "integer",
      "minimum": 0
    },
    "local_stub_draft_count": {
      "type": "integer",
      "minimum": 0
    },
    "qwen_prepaid_cheap_worker_ready": {
      "type": "boolean"
    },
    "qwen_first_applies_only_to": {
      "const": "cheap_worker_lane"
    },
    "qwen_first_must_not_override": {
      "type": "array",
      "contains": { "const": "engineering_executor_lane" }
    },
    "qwen_prepaid_usage": {
      "type": "object"
    },
    "qwen_prepaid_first_required_count": {
      "type": "integer",
      "minimum": 0
    },
    "qwen_prepaid_first_attempted_count": {
      "type": "integer",
      "minimum": 0
    },
    "qwen_prepaid_first_succeeded_count": {
      "type": "integer",
      "minimum": 0
    },
    "qwen_fallback_allowed_count": {
      "type": "integer",
      "minimum": 0
    },
    "eval_count": {
      "type": "integer",
      "minimum": 0
    },
    "audit_count": {
      "type": "integer",
      "minimum": 0
    },
    "merged_count": {
      "type": "integer",
      "minimum": 0
    },
    "spend_entry_count": {
      "type": "integer",
      "minimum": 1
    },
    "provider_tier_usage": {
      "type": "object",
      "minProperties": 1
    },
    "token_cost_spend": {
      "type": "object",
      "required": ["prompt_tokens", "completion_tokens", "total_tokens", "cost_usd"],
      "properties": {
        "total_tokens": { "type": "integer", "minimum": 1 },
        "cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "provider_schemas": {
      "type": "object",
      "required": [
        "brain_provider_schema",
        "worker_provider_schema",
        "model_gateway_route_schema",
        "executor_adapter_schema",
        "worker_brief_schema"
      ]
    },
    "can_invoke_now": {
      "type": "object",
      "required": [
        "cli",
        "direct_module",
        "callable",
        "capability",
        "dp_modes_bound",
        "search_is_main_task",
        "provider_probe_used_as_progress"
      ],
      "properties": {
        "search_is_main_task": { "const": false },
        "provider_probe_used_as_progress": { "const": false }
      }
    },
    "trigger_binding": {
      "type": "object",
      "required": [
        "status",
        "hot_path",
        "dp_worker_role",
        "search_is_main_task",
        "provider_probe_used_as_progress",
        "watchdog_role"
      ],
      "properties": {
        "status": {
          "enum": [
            "parallel_draft_to_merge_hot_path_bound",
            "control_plane_repair_hot_path_bound"
          ]
        },
        "hot_path": {
          "enum": [
            "parallel_draft->merge->writer",
            "detect_blocker->repair_lanes->fan_in_repair_evidence->resume"
          ]
        },
        "search_is_main_task": { "const": false },
        "provider_probe_used_as_progress": { "const": false },
        "watchdog_role": { "const": "downgraded_side_evidence_not_mainline" }
      }
    },
    "blocker_repair_escalation": {
      "type": "object"
    },
    "default_route_binding": {
      "type": "object",
      "required": ["status", "adoption_state", "runtime_enforced", "trigger_installed"],
      "properties": {
        "status": {
          "enum": [
            "default_route_discovery_bound",
            "global_default_candidate_blocked",
            "global_default_runtime_enforced"
          ]
        },
        "adoption_state": {
          "enum": [
            "default_hot_path_ready",
            "global_default_candidate_blocked",
            "runtime_enforced_global_default"
          ]
        },
        "runtime_enforced": { "type": "boolean" },
        "trigger_installed": { "type": "boolean" }
      }
    },
    "validation": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": { "type": "boolean" }
      }
    },
    "completion_claim_allowed": { "const": false },
    "not_source_of_truth": { "const": true },
    "not_user_completion": { "const": true },
    "not_completion_decision": { "const": true },
    "not_execution_controller": { "const": true }
  }
}
