        "not_execution_controller"
      ],
      "properties": {
        "completion_claim_allowed": {
          "const": false
        },
        "not_execution_controller": {
          "const": true
        }
      }
    },
    "fan_in": {
      "type": "object",
      "required": [
        "schema_version",
        "object_type",
        "fan_in_ref",
