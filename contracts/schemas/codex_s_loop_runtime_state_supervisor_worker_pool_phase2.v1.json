{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_loop_runtime_state_supervisor_worker_pool_phase2.v1.json",
  "title": "Codex S LoopRuntimeState Supervisor Worker Pool Phase2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "identity",
    "phase",
    "foreground_brain",
    "background",
    "active_workers",
    "task_backlog",
    "ready_frontier",
    "draft_staging",
    "merge_backlog",
    "fan_in_backlog",
    "evidence_backlog",
    "source_gaps",
    "blockers",
    "next_frontier",
    "capacity_by_lane_class",
    "acceptance",
    "evidence_ledger",
    "stop",
    "stop_hook_contract",
    "validation",
    "completion_claim_allowed",
    "not_user_completion",
    "not_completion_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.loop_runtime_state_supervisor_worker_pool_phase2.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_CODEX_S_LOOP_RUNTIME_STATE_PHASE2_V1"
    },
    "identity": {
      "type": "object",
      "required": ["work_id", "task_id", "wave_id", "loop_epoch", "checkpoint_ref", "generated_at"],
      "properties": {
        "work_id": { "const": "xinao_seed_cortex_phase0_20260701" },
        "task_id": { "const": "loop_runtime_state_supervisor_worker_pool_phase2_20260704" }
      }
    },
    "background": {
      "type": "object",
      "required": ["main_loop", "queue_consumer_main_loop", "thirty_minute_runner_is_watchdog_only"],
      "properties": {
        "main_loop": { "const": "task_queue_worker_pool_consumer" },
        "queue_consumer_main_loop": { "const": true },
        "thirty_minute_runner_is_watchdog_only": { "const": true }
      }
    },
    "capacity_by_lane_class": {
      "type": "object",
      "required": ["dp_draft", "merge_accept", "dynamic_width_record"],
      "properties": {
        "dp_draft": {
          "type": "object",
          "required": ["draft_target", "draft_is_primary"],
          "properties": {
            "draft_target": { "type": "integer", "minimum": 1 },
            "draft_is_primary": { "const": true }
          }
        },
        "dynamic_width_record": {
          "type": "object",
          "required": [
            "target_width",
            "actual_dispatched_width",
            "actual_completed_width",
            "independent_task_count",
            "provider",
            "model",
            "provider_tier",
            "token_cost_spend",
            "latency_ms",
            "queue_depth",
            "rate_limit_error",
            "retry_after",
            "staged_count",
            "merged_count",
            "named_blocker"
          ]
        }
      }
    },
    "stop": {
      "type": "object",
      "required": [
        "stop_allowed",
        "stop_reason",
        "derived",
        "computed_from_refs",
        "reason_flags",
        "user_stop_requested",
        "user_only_gate_open",
        "irreversible_hard_risk",
        "accepted_completion_ref"
      ],
      "properties": {
        "stop_allowed": { "type": "boolean" },
        "derived": { "const": true }
      }
    },
    "completion_claim_allowed": { "const": false },
    "not_user_completion": { "const": true },
    "not_completion_boundary": { "const": true }
  }
}
