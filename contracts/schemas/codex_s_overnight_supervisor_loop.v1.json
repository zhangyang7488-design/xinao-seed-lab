{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_overnight_supervisor_loop.v1.json",
  "title": "Codex S Overnight Supervisor Loop",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "task_id",
    "work_id",
    "route_profile",
    "status",
    "should_continue_loop",
    "foreground_poll_required",
    "poll_owner",
    "user_prompts_required",
    "wave_count",
    "ledger",
    "external_search",
    "capabilities",
    "a4_default_shape",
    "can_invoke_now",
    "completion_claim_allowed",
    "not_user_completion",
    "not_completion_decision",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.overnight_supervisor_loop.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_CODEX_S_OVERNIGHT_SUPERVISOR_LOOP_ACTIVE"
    },
    "task_id": {
      "const": "overnight_supervisor_loop_phase0_batch_20260704"
    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "route_profile": {
      "const": "seed_cortex_phase0"
    },
    "foreground_poll_required": {
      "const": true
    },
    "poll_owner": {
      "const": "codex_s"
    },
    "user_prompts_required": {
      "const": false
    },
    "wave_count": {
      "type": "integer",
      "minimum": 0
    },
    "ledger": {
      "type": "object",
      "required": ["succeeded_count", "split_brain_checked"],
      "properties": {
        "succeeded_count": { "type": "integer", "minimum": 0 },
        "split_brain_checked": { "const": true }
      }
    },
    "external_search": {
      "type": "object",
      "required": [
        "non_local_source_family_count",
        "minimum_two_non_local_met"
      ],
      "properties": {
        "non_local_source_family_count": { "type": "integer", "minimum": 0 },
        "minimum_two_non_local_met": { "type": "boolean" }
      }
    },
    "capabilities": {
      "type": "object",
      "required": [
        "manifest_count",
        "invoke_evidence_count",
        "directory_non_empty",
        "at_least_one_invoke_evidence"
      ],
      "properties": {
        "manifest_count": { "type": "integer", "minimum": 0 },
        "invoke_evidence_count": { "type": "integer", "minimum": 0 },
        "directory_non_empty": { "type": "boolean" },
        "at_least_one_invoke_evidence": { "type": "boolean" }
      }
    },
    "a4_default_shape": {
      "type": "object",
      "required": [
        "latest",
        "stage_order",
        "ledger_true_succeeded",
        "meta_rsi_role"
      ],
      "properties": {
        "latest": { "type": "string" },
        "stage_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ledger_true_succeeded": { "type": "boolean" },
        "meta_rsi_role": { "const": "evidence_only_not_main_worker" }
      }
    },
    "can_invoke_now": {
      "type": "object",
      "required": [
        "watchdog_status",
        "root_intent_loop_driver",
        "temporal_worker_start",
        "capability_manifest",
        "a4_default_shape_latest"
      ]
    },
    "completion_claim_allowed": { "const": false },
    "not_user_completion": { "const": true },
    "not_completion_decision": { "const": true },
    "validation": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": { "type": "boolean" },
        "checks": { "type": "object" }
      }
    }
  }
}
