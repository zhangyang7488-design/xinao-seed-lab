            "invoked_by_main_execution_loop_tick",
            "refs_ready_for_durable_packet",
            "scheduler_invocation_status",
            "scheduler_invoked",
            "parent_dispatch_invoked",
            "scheduler_spawned_lane_count",
            "current_parent_lane_evidence_state",
            "default_runtime_scheduler_invoked",
            "runtime_enforced",
            "trigger_installed",
            "completion_claim_allowed",
            "not_execution_controller",
            "refs_are_evidence_only",
            "refs_are_not_completion_gates",
            "refs_are_not_execution_controllers"
