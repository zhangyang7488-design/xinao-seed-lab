    "positive_ev_claim_allowed": {
      "type": "boolean",
      "const": false
    },
    "not_source_of_truth": {
      "type": "boolean",
      "const": true
    },
    "not_user_completion": {
      "type": "boolean",
      "const": true
    },
    "not_completion_decision": {
      "type": "boolean",
      "const": true
    },
    "not_execution_controller": {
      "type": "boolean",
      "const": true
    }
