{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_mature_binding_gap_ledger.v1.json",
  "title": "Codex S Mature Binding Gap Ledger",
  "type": "object",
  "required": [
    "schema_version",
    "sentinel",
    "task_id",
    "status",
    "state_directory_count",
    "classified_state_count",
    "category_counts",
    "classifications",
    "critical_gaps",
    "lying_layers",
    "task_contract_router",
    "p0_005",
    "completion_claim_allowed",
    "not_execution_controller",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.mature_binding_gap_ledger.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_MATURE_BINDING_GAP_LEDGER_READY"
    },
    "task_id": {
      "const": "p0_005_mature_binding_gap_ledger"
    },
    "status": {
      "enum": [
        "mature_binding_gap_ledger_ready",
        "mature_binding_gap_ledger_blocked"
      ]
    },
    "state_directory_count": {
      "type": "integer",
      "minimum": 0
    },
    "classified_state_count": {
      "type": "integer",
      "minimum": 0
    },
    "category_counts": {
      "type": "object",
      "required": ["bound", "installed_not_bound", "not_applicable", "P1_deferred"]
    },
    "classifications": {
      "type": "array",
      "items": {"$ref": "#/$defs/classification"}
    },
    "expected_missing_targets": {
      "type": "array",
      "items": {"$ref": "#/$defs/classification"}
    },
    "critical_gaps": {
      "type": "array",
      "items": {"$ref": "#/$defs/classification"}
    },
    "lying_layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state_id", "claim", "counter_evidence", "fix_shape"]
      }
    },
    "task_contract_router": {
      "type": "object",
      "required": ["contract_id", "status", "workflow_id", "workflow_run_id", "validation_passed"]
    },
    "p0_005": {
      "type": "object",
      "required": [
        "mature_binding_gap_ledger_ready",
        "success_field",
        "success_decision",
        "deliverable"
      ],
      "properties": {
        "success_field": {
          "const": "mature_binding_gap_ledger_ready"
        },
        "success_decision": {
          "const": "accepted_for_delivery"
        }
      }
    },
    "completion_claim_allowed": {
      "const": false
    },
    "not_execution_controller": {
      "const": true
    },
    "validation": {
      "type": "object",
      "required": ["passed", "checks", "validated_at"]
    }
  },
  "$defs": {
    "classification": {
      "type": "object",
      "required": [
        "state_id",
        "category",
        "reason",
        "latest_path",
        "exists",
        "completion_claim_allowed",
        "not_execution_controller"
      ],
      "properties": {
        "state_id": {"type": "string", "minLength": 1},
        "category": {
          "enum": ["bound", "installed_not_bound", "not_applicable", "P1_deferred"]
        },
        "reason": {"type": "string"},
        "latest_path": {"type": "string"},
        "exists": {"type": "boolean"},
        "status": {"type": "string"},
        "task_id": {"type": "string"},
        "evidence": {"type": "object"},
        "completion_claim_allowed": {"const": false},
        "not_execution_controller": {"const": true}
      }
    }
  }
}
