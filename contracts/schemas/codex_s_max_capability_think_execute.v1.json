{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_max_capability_think_execute.v1.json",
  "title": "Codex S Max Capability Think Execute",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "work_id",
    "route_profile",
    "task_id",
    "WORKER_ASSIGNMENT",
    "width_decision",
    "worker_dispatch_ledger",
    "fan_in",
    "artifact_acceptance",
    "summary",
    "validation",
    "completion_claim_allowed",
    "not_source_of_truth",
    "not_user_completion",
    "not_completion_decision",
    "not_execution_controller"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.max_capability_think_execute.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_CODEX_MAX_CAPABILITY_THINK_EXECUTE_RUNTIME_INVOKED"
    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "route_profile": {
      "const": "seed_cortex_phase0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "WORKER_ASSIGNMENT": {
      "type": "object",
      "required": ["think_lanes", "execute_lanes", "dependencies"],
      "properties": {
        "think_lanes": {"type": "array", "minItems": 1},
        "execute_lanes": {"type": "array", "minItems": 1},
        "dependencies": {"type": "array", "minItems": 1}
      }
    },
    "width_decision": {
      "type": "object",
      "required": [
        "width_source",
        "effective_execute_lane_count",
        "hardcoded_fixed_width_used",
        "provider_probe_default_allowed"
      ],
      "properties": {
        "width_source": {
          "const": "deepseek_dynamic_routing_policy.routing_policy.current_default_provider_width"
        },
        "effective_execute_lane_count": {"type": "integer", "minimum": 1},
        "hardcoded_fixed_width_used": {"const": false},
        "provider_probe_default_allowed": {"const": false}
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "dp_nonprobe_attempted_count",
        "dp_nonprobe_succeeded_count",
        "provider_probe_invocation_count",
        "worker_dispatch_ledger_succeeded_count",
        "synthetic_succeeded_count",
        "named_serial_exception_present"
      ],
      "properties": {
        "dp_nonprobe_attempted_count": {"type": "integer", "minimum": 1},
        "dp_nonprobe_succeeded_count": {"type": "integer", "minimum": 0},
        "provider_probe_invocation_count": {"const": 0},
        "worker_dispatch_ledger_succeeded_count": {"type": "integer", "minimum": 1},
        "synthetic_succeeded_count": {"const": 0},
        "named_serial_exception_present": {"type": "boolean"}
      }
    },
    "hook_binding": {
      "type": "object",
      "required": ["adoption_state", "temporal_worker_dispatch_ledger_activity_hooked"],
      "properties": {
        "adoption_state": {"const": "hooked_runtime_entrypoint"},
        "temporal_worker_dispatch_ledger_activity_hooked": {"const": true}
      }
    },
    "phase0_closure_dag": {
      "type": "object",
      "required": ["status", "ledger_adoption_state", "should_continue_loop", "nodes"],
      "properties": {
        "status": {"const": "ready"},
        "ledger_adoption_state": {"const": "hooked_runtime_entrypoint"},
        "should_continue_loop": {"const": true},
        "nodes": {"type": "array", "minItems": 6}
      }
    },
    "validation": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": {"type": "boolean"},
        "checks": {"type": "object"}
      }
    },
    "completion_claim_allowed": {"const": false},
    "not_source_of_truth": {"const": true},
    "not_user_completion": {"const": true},
    "not_completion_decision": {"const": true},
    "not_execution_controller": {"const": true}
  }
}
