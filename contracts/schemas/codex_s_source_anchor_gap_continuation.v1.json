{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/schemas/codex_s_source_anchor_gap_continuation.v1.json",
  "title": "Codex S Source Anchor Gap Continuation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "status",
    "source_anchors",
    "runtime_refs",
    "source_anchor_coverage",
    "coverage_gate_decision",
    "continue_dispatch_expected",
    "next_loop_packet",
    "stop_hook_may_use_as_decision_input",
    "not_source_of_truth",
    "not_user_completion",
    "not_completion_decision",
    "not_execution_controller"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.source_anchor_gap_continuation.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_CODEX_S_SOURCE_ANCHOR_GAP_CONTINUATION_READY"
    },
    "status": {
      "const": "source_anchor_gap_continuation_ready"
    },
    "source_anchor_complete": {
      "type": "boolean"
    },
    "runtime_ref_complete": {
      "type": "boolean"
    },
    "source_text_debt_open": {
      "type": "boolean"
    },
    "auto_task_slicing_enabled": {
      "const": false
    },
    "source_anchor_task_slicing_frozen": {
      "const": true
    },
    "continue_dispatch_expected": {
      "type": "boolean"
    },
    "stop_hook_may_use_as_decision_input": {
      "const": true
    },
    "coverage_gate_decision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "report_allowed",
        "stop_allowed",
        "continuation_required",
        "source_text_debt_open",
        "next_machine_action"
      ],
      "properties": {
        "report_allowed": {
          "const": true
        },
        "stop_allowed": {
          "type": "boolean"
        },
        "continuation_required": {
          "type": "boolean"
        },
        "source_text_debt_open": {
          "type": "boolean"
        },
        "next_machine_action": {
          "type": "string"
        }
      }
    },
    "source_anchor_coverage": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "coverage_complete",
        "source_text_debt_open",
        "auto_task_slicing_enabled",
        "frozen_by_user",
        "source_text_obligation_count",
        "sampled_obligation_count",
        "task_slices_ref",
        "next_task_card_ref"
      ],
      "properties": {
        "coverage_complete": {
          "type": "boolean"
        },
        "source_text_debt_open": {
          "type": "boolean"
        },
        "auto_task_slicing_enabled": {
          "const": false
        },
        "frozen_by_user": {
          "const": true
        },
        "source_text_obligation_count": {
          "type": "integer",
          "minimum": 0
        },
        "sampled_obligation_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "not_source_of_truth": {
      "const": true
    },
    "not_user_completion": {
      "const": true
    },
    "not_completion_decision": {
      "const": true
    },
    "not_execution_controller": {
      "const": true
    }
  }
}
