{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_scheduler_invocation_packet.v1.json",
  "title": "Codex S Scheduler Invocation Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "sentinel",
    "work_id",
    "route_profile",
    "object_id",
    "generated_at",
    "status",
    "adoption_state",
    "spawn_evidence_state",
    "named_blocker",
    "scheduler_invoked",
    "invoked_by",
    "invocation_scope",
    "manual_parent_dispatch",
    "parent_dispatch_invoked",
    "callable_scheduler_invocation_ref",
    "scheduler_invocation_refs",
    "spawned_lanes",
    "scheduler_spawned_lane_refs",
    "spawned_lane_count",
    "actual_spawned_lane_ref_present",
    "current_parent_codex_subagent_ref_count",
    "dp_sidecar_execution_lane_ref_count",
    "dp_sidecar_execution_lanes_spawned",
    "poll_refs",
    "fan_in_refs",
    "evidence_refs",
    "readback_refs",
    "adoption_boundary",
    "legacy_5d33_role",
    "legacy_5d33_owner_reused",
    "runtime_enforced",
    "default_runtime_scheduler_invoked",
    "completion_claim_allowed",
    "phase0_completion_claim_allowed",
    "not_source_of_truth",
    "not_user_completion",
    "not_completion_decision",
    "not_execution_controller",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.scheduler_invocation_packet.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_SCHEDULER_INVOCATION_PACKET_READY"
    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "route_profile": {
      "const": "seed_cortex_phase0"
    },
    "object_id": {
      "const": "scheduler_invocation_packet"
    },
    "status": {
      "enum": [
        "spawned_lane_refs_recorded",
        "blocked/planned_only",
        "scheduler_invocation_packet_validation_blocked"
      ]
    },
    "adoption_state": {
      "const": "verifier_ready_but_not_hooked"
    },
    "spawn_evidence_state": {
      "enum": [
        "spawned_lane_refs_recorded",
        "blocked/planned_only",
        "scheduler_invocation_packet_validation_blocked"
      ]
    },
    "named_blocker": {
      "type": "string"
    },
    "scheduler_invoked": {
      "type": "boolean"
    },
    "invoked_by": {
      "type": "string"
    },
    "invocation_scope": {
      "type": "string"
    },
    "manual_parent_dispatch": {
      "type": "boolean"
    },
    "parent_dispatch_invoked": {
      "type": "boolean"
    },
    "callable_scheduler_invocation_ref": {
      "type": "string"
    },
    "scheduler_invocation_refs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "current_parent_codex_invocation_ref",
        "callable_scheduler_invocation_ref",
        "default_runtime_scheduler_hook_ref",
        "dp_launcher_ref",
        "refs_are_task_scoped_evidence",
        "refs_are_not_default_runtime_enforcement"
      ],
      "properties": {
        "refs_are_task_scoped_evidence": {
          "const": true
        },
        "refs_are_not_default_runtime_enforcement": {
          "const": true
        }
      }
    },
    "spawned_lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "lane_kind",
          "lane_ref",
          "actual_ref",
          "source",
          "spawned_by",
          "not_execution_controller"
        ],
        "properties": {
          "lane_kind": {
            "enum": [
              "current_parent_codex_subagent",
              "callable_scheduler_entrypoint_lane",
              "dp_sidecar_execution",
              "local_tool_lane",
              "temporal_activity_lane",
              "other_actual_lane"
            ]
          },
          "lane_ref": {
            "type": "string",
            "minLength": 1
          },
          "actual_ref": {
            "const": true
          },
          "not_execution_controller": {
            "const": true
          }
        }
      }
    },
    "scheduler_spawned_lane_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "lane_kind",
          "lane_ref",
          "actual_ref",
          "source",
          "spawned_by",
          "poll_status",
          "dispatch_status",
          "not_execution_controller"
        ],
        "properties": {
          "lane_kind": {
            "enum": [
              "current_parent_codex_subagent",
              "callable_scheduler_entrypoint_lane",
              "dp_sidecar_execution",
              "local_tool_lane",
              "temporal_activity_lane",
              "other_actual_lane"
            ]
          },
          "lane_ref": {
            "type": "string",
            "minLength": 1
          },
          "actual_ref": {
            "const": true
          },
          "not_execution_controller": {
            "const": true
          }
        }
      }
    },
    "spawned_lane_count": {
      "type": "integer",
      "minimum": 0
    },
    "actual_spawned_lane_ref_present": {
      "type": "boolean"
    },
    "current_parent_codex_subagent_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "dp_sidecar_execution_lane_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "dp_sidecar_execution_lanes_spawned": {
      "type": "boolean"
    },
    "poll_refs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "live_backend_watch_ref",
        "worker_dispatch_ledger_ref",
        "poll_required_before_fan_in",
        "poll_refs_are_evidence_only"
      ],
      "properties": {
        "poll_required_before_fan_in": {
          "const": true
        },
        "poll_refs_are_evidence_only": {
          "const": true
        }
      }
    },
    "fan_in_refs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "parallel_fan_in_acceptance_ref",
        "artifact_acceptance_queue_ref",
        "fan_in_required_before_fact_promotion",
        "artifact_acceptance_queue_required",
        "direct_fact_promotion_allowed"
      ],
      "properties": {
        "fan_in_required_before_fact_promotion": {
          "const": true
        },
        "artifact_acceptance_queue_required": {
          "const": true
        },
        "direct_fact_promotion_allowed": {
          "const": false
        }
      }
    },
    "evidence_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_latest",
        "runtime_readback_zh",
        "schema",
        "writer",
        "tests",
        "verifier",
        "durable_parallel_wave_packet_latest",
        "scheduler_spawned_lane_evidence_latest",
        "worker_dispatch_ledger_latest"
      ],
      "properties": {
        "runtime_latest": {
          "type": "string",
          "pattern": "state[\\\\/]scheduler_invocation_packet[\\\\/]latest\\.json$"
        },
        "runtime_readback_zh": {
          "type": "string",
          "pattern": "readback[\\\\/]zh[\\\\/]scheduler_invocation_packet_20260703\\.md$"
        },
        "schema": {
          "type": "string"
        },
        "writer": {
          "type": "string"
        },
        "tests": {
          "type": "string"
        },
        "verifier": {
          "type": "string"
        },
        "durable_parallel_wave_packet_latest": {
          "type": "string"
        },
        "scheduler_spawned_lane_evidence_latest": {
          "type": "string"
        },
        "worker_dispatch_ledger_latest": {
          "type": "string"
        }
      }
    },
    "readback_refs": {
      "type": "object",
      "required": [
        "runtime_readback_zh",
        "human_visible_readback_required"
      ],
      "properties": {
        "human_visible_readback_required": {
          "const": true
        }
      }
    },
    "legacy_5d33_role": {
      "const": "reference_only"
    },
    "legacy_5d33_owner_reused": {
      "const": false
    },
    "runtime_enforced": {
      "const": false
    },
    "default_runtime_scheduler_invoked": {
      "const": false
    },
    "completion_claim_allowed": {
      "const": false
    },
    "phase0_completion_claim_allowed": {
      "const": false
    },
    "not_source_of_truth": {
      "const": true
    },
    "not_user_completion": {
      "const": true
    },
    "not_completion_decision": {
      "const": true
    },
    "not_execution_controller": {
      "const": true
    },
    "validation": {
      "type": "object",
      "required": [
        "passed",
        "checks",
        "validated_at"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "object"
        },
        "validated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
