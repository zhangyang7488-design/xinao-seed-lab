{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_productivity_baseline.v1.json",
  "title": "Codex productivity vs gatekeeper baseline probe",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "probe_id",
    "task_id",
    "had_code_diff",
    "had_invoke",
    "gatekeeper_signals",
    "zh_readback",
    "written_at",
    "not_user_completion"
  ],
  "properties": {
    "schema_version": { "const": "xinao.codex_productivity_baseline.v1" },
    "probe_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string" },
    "wave_id": { "type": "string" },
    "had_code_diff": { "type": "boolean" },
    "had_invoke": { "type": "boolean" },
    "invoke_path": { "type": "string" },
    "gatekeeper_signals": {
      "type": "array",
      "items": {
        "enum": [
          "report_only_stop",
          "pytest_pass_stop",
          "read_only_inventory",
          "verifier_marathon_no_diff",
          "none_observed"
        ]
      }
    },
    "zh_readback": { "type": "string", "minLength": 1 },
    "written_at": { "type": "string" },
    "not_user_completion": { "const": true }
  }
}