{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/schemas/codex_s_task_package_manifest.v1.json",
  "title": "Codex S Task Package Manifest",
  "type": "object",
  "required": ["schema_version", "package_mode", "resources"],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.task_package_manifest.v1"
    },
    "package_mode": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "role"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|/)\\.\\.(/|$)).+"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "read": {
            "type": "string",
            "enum": ["full", "reference_only", "skip", "none"]
          },
          "mediatype": {
            "type": "string"
          },
          "encoding": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "excluded": {
      "type": "array"
    },
    "execution_defaults": {
      "type": "object",
      "required": [
        "north_star",
        "default_acceptance_decisions",
        "exception_acceptance_decision",
        "next_frontier_default_outlet",
        "task_shape",
        "bounded_retry"
      ],
      "properties": {
        "north_star": {
          "const": "user_x_to_deliverable_y"
        },
        "task_shape": {
          "const": "one_deliverable_one_binding_one_verifier"
        },
        "default_acceptance_decisions": {
          "type": "array",
          "prefixItems": [
            {
              "const": "accepted_for_binding"
            },
            {
              "const": "accepted_for_delivery"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "exception_acceptance_decision": {
          "const": "accepted_for_next_frontier"
        },
        "next_frontier_default_outlet": {
          "const": false
        },
        "forbid_background_self_proof_without_deliverable": {
          "const": true
        },
        "bounded_retry": {
          "type": "object",
          "required": [
            "policy_id",
            "scope",
            "max_attempts",
            "max_recursive_repairs",
            "next_frontier_on_failure",
            "failure_terminal_state"
          ],
          "properties": {
            "policy_id": {
              "const": "bounded_delivery_retry"
            },
            "scope": {
              "const": "same_deliverable_only"
            },
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "max_recursive_repairs": {
              "type": "integer",
              "minimum": 0
            },
            "next_frontier_on_failure": {
              "const": false
            },
            "failure_terminal_state": {
              "const": "named_blocker"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "mature_bind_queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "status",
          "deliverable",
          "replace_target",
          "mature_carrier",
          "thin_adapter",
          "default_mainline_binding",
          "runtime_evidence",
          "verification",
          "acceptance",
          "fallback_or_blocker"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ready", "blocked", "accepted_for_binding", "accepted_for_delivery", "deferred", "done"]
          },
          "deliverable": {
            "type": "string",
            "minLength": 1
          },
          "replace_target": {
            "type": "string",
            "minLength": 1
          },
          "mature_carrier": {
            "type": "string",
            "minLength": 1
          },
          "thin_adapter": {
            "type": "string",
            "minLength": 1
          },
          "default_mainline_binding": {
            "type": "string",
            "minLength": 1
          },
          "runtime_evidence": {
            "type": "array",
            "minItems": 1
          },
          "verification": {
            "type": "array",
            "minItems": 1
          },
          "acceptance": {
            "type": "object",
            "required": ["success_decision"]
          },
          "fallback_or_blocker": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "external_mature_basis": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
