{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/meta_rsi_wave.v1.json",
  "title": "MetaRsiWave candidate record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "wave_id",
    "task_id",
    "mode",
    "adoption_state",
    "runtime_enforced",
    "completion_claim_allowed",
    "written_at"
  ],
  "properties": {
    "schema_version": { "const": "xinao.meta_rsi_wave.v1" },
    "wave_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "mode": {
      "enum": ["repo_safe", "max_parallel", "research", "repair", "audit", "productivity_v2"]
    },
    "mode_reason": { "type": "string" },
    "fallback": {
      "type": "object",
      "properties": {
        "repo_mode_used": { "type": "boolean" },
        "reason": {
          "enum": [
            "runtime_unavailable",
            "low_confidence",
            "destructive_risk",
            "user_no_runtime",
            "fanin_overload",
            "none"
          ]
        }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lane_id", "kind", "expected_artifact"],
        "properties": {
          "lane_id": { "type": "string" },
          "phase": {
            "enum": ["restore", "think", "execute", "verify", "fan_in", "readback"]
          },
          "kind": {
            "enum": ["repo", "runtime", "dp_sidecar", "search", "audit", "draft", "verify"]
          },
          "goal": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "expected_artifact": {
            "enum": [
              "ClaimCard",
              "patch",
              "test_result",
              "evidence_ref",
              "blocker",
              "capability_invoke"
            ]
          }
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lane_id", "status"],
        "properties": {
          "lane_id": { "type": "string" },
          "status": { "enum": ["accepted", "rejected", "blocked"] },
          "artifact_refs": { "type": "array", "items": { "type": "string" } },
          "accepted_for": {
            "enum": [
              "NextFrontier",
              "ArtifactAcceptanceQueue",
              "repo_answer",
              "blocker",
              "capability_invoke"
            ]
          },
          "notes_zh": { "type": "string" }
        }
      }
    },
    "execution_contract": {
      "type": "object",
      "required": ["contract_id", "required_sequence", "must_not_stop_at"],
      "properties": {
        "contract_id": { "type": "string" },
        "authority_anchor": { "type": "string" },
        "authority_scope": { "type": "string" },
        "serves": {
          "type": "array",
          "items": { "type": "string" }
        },
        "not_authority_source": { "type": "boolean" },
        "not_control_plane": { "type": "boolean" },
        "not_fact_source": { "type": "boolean" },
        "not_bypass_island": { "type": "boolean" },
        "plain_zh": { "type": "string" },
        "required_sequence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_not_stop_at": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_produce_one_of": {
          "type": "array",
          "items": { "type": "string" }
        },
        "draft_merge_chain": {
          "type": "object",
          "properties": {
            "required_when_applicable": { "type": "boolean" },
            "shape": { "type": "string" },
            "meta_rsi_role": { "type": "string" },
            "search_role": { "type": "string" }
          }
        },
        "default_route_claim_rule": { "type": "string" }
      }
    },
    "adoption_state": { "const": "candidate_registered" },
    "runtime_enforced": { "const": false },
    "completion_claim_allowed": { "const": false },
    "zh_readback": { "type": "string" },
    "written_at": { "type": "string" },
    "not_user_completion": { "const": true }
  }
}
