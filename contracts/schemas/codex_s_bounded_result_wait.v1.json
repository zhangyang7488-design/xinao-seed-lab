{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_bounded_result_wait.v1.json",
  "title": "Codex S Bounded Result Wait",
  "type": "object",
  "required": [
    "schema_version",
    "sentinel",
    "task_id",
    "status",
    "bounded_result_wait_ready",
    "current_state",
    "current_workflow_id",
    "current_workflow_run_id",
    "worker_status",
    "named_blocker",
    "wait_timeout_seconds",
    "next_machine_action_cn",
    "completion_claim_allowed",
    "not_execution_controller",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.bounded_result_wait.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_BOUNDED_RESULT_WAIT_READY"
    },
    "task_id": {
      "const": "p0_009_bounded_result_wait"
    },
    "status": {
      "enum": [
        "bounded_result_wait_ready",
        "bounded_result_wait_blocked"
      ]
    },
    "bounded_result_wait_ready": {
      "type": "boolean"
    },
    "current_state": {
      "enum": [
        "waiting",
        "timed_out",
        "blocked",
        "completed",
        "idle",
        "result_ready",
        "running"
      ]
    },
    "completion_claim_allowed": {
      "const": false
    },
    "not_execution_controller": {
      "const": true
    }
  },
  "additionalProperties": true
}