{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/contracts/codex_s_wave2_mainchain_hygiene.v1.json",
  "title": "Codex S Wave2 Mainchain Hygiene",
  "type": "object",
  "required": [
    "schema_version",
    "sentinel",
    "work_id",
    "parent_task_id",
    "task_id",
    "routing",
    "source_package",
    "block_sequence",
    "default_main_loop_hygiene",
    "black_window_probe",
    "memo_gap_refresh",
    "next_frontier_machine_actions",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.codex_s.wave2_mainchain_hygiene.v1"
    },
    "sentinel": {
      "const": "SENTINEL:XINAO_WAVE2_MAINCHAIN_HYGIENE_READY"
    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "parent_task_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "task_id": {
      "const": "wave2_mainchain_hygiene_20260704"
    },
    "routing": {
      "const": "continue_same_task"
    },
    "source_package": {
      "type": "object",
      "required": ["all_required_sources_read_full", "source_package_digest_sha256"],
      "properties": {
        "all_required_sources_read_full": { "const": true },
        "source_package_digest_sha256": { "type": "string", "minLength": 32 }
      }
    },
    "block_sequence": {
      "type": "object",
      "required": ["block3_source_frontier", "block4_source_family", "block5_phase0_kernel"]
    },
    "default_main_loop_hygiene": {
      "type": "object",
      "required": ["default_main_loop", "single_default_while", "event_backlog_frontier_driven", "thirty_minute_runner"],
      "properties": {
        "default_main_loop": { "const": "temporal_activity_event_queue_loop" },
        "single_default_while": { "const": true },
        "event_backlog_frontier_driven": { "const": true }
      }
    },
    "black_window_probe": {
      "type": "object",
      "required": ["black_window_issue_handled", "visible_disallowed_cmd_powershell_python_count"],
      "properties": {
        "black_window_issue_handled": { "const": true },
        "visible_disallowed_cmd_powershell_python_count": { "const": 0 }
      }
    },
    "memo_gap_refresh": {
      "type": "object",
      "required": ["counts"],
      "properties": {
        "counts": {
          "type": "object",
          "required": ["total_targets", "landed_or_migrated", "partial", "gap"],
          "properties": {
            "total_targets": { "const": 13 },
            "landed_or_migrated": { "const": 13 },
            "partial": { "const": 0 },
            "gap": { "const": 0 }
          }
        }
      }
    },
    "next_frontier_machine_actions": {
      "type": "object",
      "required": ["stop_allowed", "next_frontier"],
      "properties": {
        "stop_allowed": { "const": false },
        "next_frontier": { "type": "array", "minItems": 1 }
      }
    },
    "validation": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": { "const": true },
        "checks": { "type": "object" }
      }
    }
  }
}
