        "brief_count",
        "briefs",
        "completion_claim_allowed",
        "not_execution_controller"
      ],
      "properties": {
        "schema_version": {
          "const": "xinao.codex_s.worker_brief_queue.source_bound.v1"
        },
        "brief_count": {
          "type": "integer",
          "minimum": 1
        },
        "completion_claim_allowed": {
          "const": false
        },
        "not_execution_controller": {
          "const": true
        }
      }
    },
    "worker_brief_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "worker_brief_id",
          "source_batch_id",
          "frontier_batch_id",
          "claim_card_id",
          "claim_card_ref",
          "source_package_ref",
          "mapping_key",
          "objective",
          "expected_artifact",
          "provider_policy",
          "fan_in_target",
          "aaq_target",
          "next_frontier_policy",
