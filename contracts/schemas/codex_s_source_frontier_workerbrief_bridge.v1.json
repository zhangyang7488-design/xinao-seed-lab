    },
    "work_id": {
      "const": "xinao_seed_cortex_phase0_20260701"
    },
    "task_id": {
      "const": "source_frontier_workerpool_global_closure_20260704"
    },
    "routing": {
      "const": "continue_same_task"
    },
    "route_profile": {
      "const": "seed_cortex_phase0"
    },
    "status": {
      "enum": [
        "source_frontier_workerbrief_bridge_ready",
        "source_frontier_workerbrief_bridge_blocked"
      ]
    },
    "source_frontier_to_workerbrief_binding": {
      "const": true
    },
    "thin_binding_only": {
      "const": true
    },
    "not_new_control_plane": {
      "const": true
    },
    "allocation_plan_is_canonical_lane_envelope": {
      "const": true
    },
    "source_frontier_items": {
      "type": "array",
      "minItems": 1
