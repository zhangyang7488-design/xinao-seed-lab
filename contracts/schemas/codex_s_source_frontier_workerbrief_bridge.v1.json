        "properties": {
          "worker_output_must_enter_staging": {
            "const": true
          },
          "direct_final_allowed": {
            "const": false
          },
          "completion_claim_allowed": {
            "const": false
          },
          "not_execution_controller": {
            "const": true
          }
        }
      }
    },
    "latest_alias_is_not_proof": {
      "const": true
    },
    "completion_claim_allowed": {
      "const": false
    },
    "not_source_of_truth": {
      "const": true
    },
    "not_user_completion": {
      "const": true
    },
    "not_completion_decision": {
      "const": true
    },
    "not_completion_gate": {
      "const": true
    },
    "not_execution_controller": {
      "const": true
    },
    "validation": {
      "type": "object",
      "required": [
        "passed",
        "checks"
      ],
      "properties": {
        "passed": {
          "const": true
        }
      }
    }
