  "additionalProperties": false,
  "description": "Minimum typed message envelope for all human/agent handoffs.",
  "properties": {
    "message_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "title": "Message Id",
      "type": "string"
    },
    "schema_version": {
      "const": "xinao.agent_handoff.v1",
      "default": "xinao.agent_handoff.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "minLength": 1,
      "title": "Session Id",
      "type": "string"
    },
    "workflow_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workflow Id"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "correlation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "title": "Correlation Id",
      "type": "string"
    },
    "handoff_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "title": "Handoff Id",
      "type": "string"
    },
    "thread_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "title": "Thread Id",
      "type": "string"
    },
    "parent_id": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Id"
    },
    "causation_id": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Causation Id"
    },
    "actor": {
      "minLength": 1,
      "title": "Actor",
      "type": "string"
    },
    "target_object": {
      "minLength": 1,
      "title": "Target Object",
      "type": "string"
    },
    "authority_scope": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Authority Scope",
      "type": "array"
    },
    "scope": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Scope",
      "type": "array"
    },
    "assumptions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "artifact_refs": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "running",
        "completed",
        "rejected",
        "blocked",
        "cancel_requested",
        "paused"
      ],
      "title": "Status",
      "type": "string"
    },
    "expiry": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expiry"
    },
    "idempotency_key": {
      "minLength": 1,
      "title": "Idempotency Key",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "payload": {
      "discriminator": {
        "mapping": {
          "Artifact": "#/$defs/ArtifactPayload",
          "Blocker": "#/$defs/BlockerPayload",
          "CandidateProposal": "#/$defs/CandidateProposalPayload",
          "Claim": "#/$defs/ClaimPayload",
          "Critique": "#/$defs/CritiquePayload",
          "Decision": "#/$defs/DecisionPayload",
          "Evidence": "#/$defs/EvidencePayload",
          "EvidenceBundle": "#/$defs/EvidenceBundlePayload",
          "Intent": "#/$defs/IntentPayload",
          "Question": "#/$defs/QuestionPayload",
          "ResearchQuestion": "#/$defs/ResearchQuestionPayload",
          "Resume": "#/$defs/ResumePayload",
          "Review": "#/$defs/ReviewPayload",
          "Stop": "#/$defs/StopPayload",
          "Task": "#/$defs/TaskPayload",
          "VerificationResult": "#/$defs/VerificationResultPayload"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/IntentPayload"
        },
        {
          "$ref": "#/$defs/QuestionPayload"
        },
        {
          "$ref": "#/$defs/DecisionPayload"
        },
        {
          "$ref": "#/$defs/TaskPayload"
        },
        {
          "$ref": "#/$defs/ClaimPayload"
        },
        {
          "$ref": "#/$defs/EvidencePayload"
        },
        {
          "$ref": "#/$defs/ArtifactPayload"
        },
        {
          "$ref": "#/$defs/ReviewPayload"
        },
        {
          "$ref": "#/$defs/BlockerPayload"
        },
        {
          "$ref": "#/$defs/StopPayload"
        },
        {
          "$ref": "#/$defs/ResumePayload"
        },
        {
          "$ref": "#/$defs/ResearchQuestionPayload"
        },
        {
          "$ref": "#/$defs/EvidenceBundlePayload"
        },
        {
          "$ref": "#/$defs/CandidateProposalPayload"
        },
        {
          "$ref": "#/$defs/CritiquePayload"
        },
        {
          "$ref": "#/$defs/VerificationResultPayload"
        }
      ],
      "title": "Payload"
    }
  },
  "required": [
    "message_id",
    "session_id",
    "correlation_id",
    "handoff_id",
    "thread_id",
    "actor",
    "target_object",
    "authority_scope",
    "scope",
    "status",
    "idempotency_key",
    "created_at",
