+    void ControlInteractivity::_sendCodexComposerPointer(
+        const til::point terminalPosition,
+        const ::Microsoft::Terminal::Core::ControlKeyStates modifiers,
+        const bool release,
+        const bool drag)
+    {
+        auto code = drag ? 32 : 0;
+        code += modifiers.IsShiftPressed() ? 4 : 0;
+        code += modifiers.IsAltPressed() ? 8 : 0;
+        code += modifiers.IsCtrlPressed() ? 16 : 0;
+        const auto terminator = release ? L'm' : L'M';
+        const auto sequence = fmt::format(
+            FMT_COMPILE(L"\x1b[<{};{};{}{}"),
+            code,
+            terminalPosition.x + 1,
+            terminalPosition.y + 1,
+            terminator);
+        _core->SendInput(sequence);
+    }
