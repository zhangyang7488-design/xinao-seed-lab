+void TerminalCoreUnitTests::TerminalApiTest::CodexComposerRegionStrictParsing()
+{
+    Terminal term{ Terminal::TestDummyMarker{} };
+    DummyRenderer renderer{ &term };
+    term.Create({ 10, 4 }, 0, renderer);
+
+    constexpr auto valid = L"CodexComposer;1;00000000000000a1;7;10;4;1;0;0;5;2;0;0";
+    term.SetCodexComposerRegion(valid);
+    VERIFY_IS_TRUE(term._codexComposerRegion.has_value());
+    VERIFY_ARE_EQUAL(0xa1ull, term._codexComposerRegion->token);
+    VERIFY_ARE_EQUAL(7ull, term._codexComposerRegion->generation);
+
+    const auto verifyRejectedWithoutReplacing = [&](const std::wstring_view declaration) {
+        term.SetCodexComposerRegion(declaration);
+        VERIFY_IS_TRUE(term._codexComposerRegion.has_value());
+        VERIFY_ARE_EQUAL(0xa1ull, term._codexComposerRegion->token);
+        VERIFY_ARE_EQUAL(7ull, term._codexComposerRegion->generation);
+        VERIFY_ARE_EQUAL((til::rect{ til::point{ 0, 0 }, til::size{ 5, 2 } }), term._codexComposerRegion->area);
+    };
+
+    // The protocol is intentionally fixed at exactly 13 fields.
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;00000000000000a2;8;10;4;1;0;0;5;2;0");
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;00000000000000a2;8;10;4;1;0;0;5;2;0;0;extra");
+    verifyRejectedWithoutReplacing(L"CodexComposer;2;00000000000000a2;8;10;4;1;0;0;5;2;0;0");
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;0000000000000a2;8;10;4;1;0;0;5;2;0;0");
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;00000000000000a2;8x;10;4;1;0;0;5;2;0;0");
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;00000000000000a2;8;11;4;1;0;0;5;2;0;0");
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;00000000000000a2;8;10;4;2;0;0;5;2;0;0");
+    verifyRejectedWithoutReplacing(L"CodexComposer;1;00000000000000a2;8;10;4;9;0;0;5;2;0;0");
+
+    // A malformed declaration must not create authority when no known-good state exists.
+    term._codexComposerRegion.reset();
+    term.SetCodexComposerRegion(L"CodexComposer;1;00000000000000a2;8;10;4;2;0;0;5;2;0;0");
+    VERIFY_IS_FALSE(term._codexComposerRegion.has_value());
