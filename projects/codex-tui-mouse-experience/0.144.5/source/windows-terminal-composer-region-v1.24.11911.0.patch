+    std::optional<::Microsoft::Terminal::Core::Terminal::CodexComposerGestureIdentity> ControlCore::TryBeginCodexComposerGesture(const til::point viewportPosition)
+    {
+        std::optional<::Microsoft::Terminal::Core::Terminal::CodexComposerGestureIdentity> identity;
+        {
+            const auto lock = _terminal->LockForReading();
+            identity = _terminal->GetCodexComposerGestureAt(viewportPosition);
+        }
+        if (!identity || !_isCodexComposerProcessAlive(identity->token))
+        {
+            return std::nullopt;
+        }
+        return identity;
+    }
+
+    bool ControlCore::IsCodexComposerGestureValid(const ::Microsoft::Terminal::Core::Terminal::CodexComposerGestureIdentity& identity)
+    {
+        bool valid = false;
+        {
+            const auto lock = _terminal->LockForReading();
+            valid = _terminal->IsCodexComposerGestureValid(identity);
+        }
+        return valid && _isCodexComposerProcessAlive(identity.token);
+    }
+
+    bool ControlCore::_isCodexComposerProcessAlive(const uint64_t token) const
+    {
+        if (!_connection)
+        {
+            return false;
+        }
+
+        const auto session = _connection.SessionId();
+        if (session == winrt::guid{})
+        {
+            return false;
+        }
+
+        const auto sessionText = ::Microsoft::Console::Utils::GuidToPlainString(session);
+        const auto eventName = fmt::format(
+            FMT_COMPILE(L"Local\\Xinao.CodexComposer.v1.{}.{:016x}"),
+            sessionText,
+            token);
+        const wil::unique_handle liveness{ OpenEventW(SYNCHRONIZE, FALSE, eventName.c_str()) };
+        return static_cast<bool>(liveness);
+    }
+
+    til::point ControlCore::ClampToViewport(til::point viewportPosition)
+    {
+        const auto lock = _terminal->LockForReading();
+        const auto size = _terminal->GetViewport().Dimensions();
+        if (size.width <= 0 || size.height <= 0)
+        {
+            return {};
+        }
+        viewportPosition.x = std::clamp(viewportPosition.x, 0, size.width - 1);
+        viewportPosition.y = std::clamp(viewportPosition.y, 0, size.height - 1);
+        return viewportPosition;
+    }
