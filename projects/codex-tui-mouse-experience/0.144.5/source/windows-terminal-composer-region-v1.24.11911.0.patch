+    bool _parseUnsignedDecimal(const std::wstring_view text, const uint64_t maximum, uint64_t& value) noexcept
+    {
+        if (text.empty())
+        {
+            return false;
+        }
+
+        uint64_t parsed = 0;
+        for (const auto ch : text)
+        {
+            if (ch < L'0' || ch > L'9')
+            {
+                return false;
+            }
+            const auto digit = static_cast<uint64_t>(ch - L'0');
+            const auto quotient = maximum / 10;
+            const auto remainder = maximum % 10;
+            if (parsed > quotient || (parsed == quotient && digit > remainder))
+            {
+                return false;
+            }
+            parsed = parsed * 10 + digit;
+        }
+        value = parsed;
+        return true;
+    }
+
+    bool _parseFixedHexToken(const std::wstring_view text, uint64_t& value) noexcept
+    {
+        if (text.size() != 16)
+        {
+            return false;
+        }
+
+        uint64_t parsed = 0;
+        for (const auto ch : text)
+        {
+            uint64_t digit = 0;
+            if (ch >= L'0' && ch <= L'9')
+            {
+                digit = static_cast<uint64_t>(ch - L'0');
+            }
+            else if (ch >= L'a' && ch <= L'f')
+            {
+                digit = static_cast<uint64_t>(ch - L'a' + 10);
+            }
+            else if (ch >= L'A' && ch <= L'F')
+            {
+                digit = static_cast<uint64_t>(ch - L'A' + 10);
+            }
+            else
+            {
+                return false;
+            }
+            parsed = (parsed << 4) | digit;
+        }
+        value = parsed;
+        return true;
+    }
+}
