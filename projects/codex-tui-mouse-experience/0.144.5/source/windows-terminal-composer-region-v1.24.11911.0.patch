+void Terminal::SetCodexComposerRegion(const std::wstring_view declaration)
+{
+    // Format:
+    // CodexComposer;1;TOKEN16;GEN;COLS;ROWS;ENABLED;X;Y;WIDTH;HEIGHT;CURSOR_X;CURSOR_Y
+    // Keep the parser deliberately fixed-width and fail closed for unknown or malformed input.
+    if (declaration.size() > 192)
+    {
+        return;
+    }
+
+    const auto parts = Microsoft::Console::Utils::SplitString(declaration, L';');
+    if (parts.size() != 13 || parts[0] != L"CodexComposer" || parts[1] != L"1")
+    {
+        return;
+    }
+
+    uint64_t token = 0;
+    uint64_t generation = 0;
+    uint64_t columns = 0;
+    uint64_t rows = 0;
+    uint64_t enabled = 0;
+    uint64_t x = 0;
+    uint64_t y = 0;
+    uint64_t width = 0;
+    uint64_t height = 0;
+    uint64_t cursorX = 0;
+    uint64_t cursorY = 0;
+    constexpr auto coordMaximum = static_cast<uint64_t>(std::numeric_limits<til::CoordType>::max());
+
+    if (!_parseFixedHexToken(parts[2], token) ||
+        !_parseUnsignedDecimal(parts[3], UINT64_MAX, generation) ||
+        !_parseUnsignedDecimal(parts[4], coordMaximum, columns) ||
+        !_parseUnsignedDecimal(parts[5], coordMaximum, rows) ||
+        !_parseUnsignedDecimal(parts[6], 1, enabled) ||
+        !_parseUnsignedDecimal(parts[7], coordMaximum, x) ||
+        !_parseUnsignedDecimal(parts[8], coordMaximum, y) ||
+        !_parseUnsignedDecimal(parts[9], coordMaximum, width) ||
+        !_parseUnsignedDecimal(parts[10], coordMaximum, height) ||
+        !_parseUnsignedDecimal(parts[11], coordMaximum, cursorX) ||
+        !_parseUnsignedDecimal(parts[12], coordMaximum, cursorY))
+    {
+        return;
+    }
+
+    if (_codexComposerRegion && _codexComposerRegion->token == token && generation <= _codexComposerRegion->generation)
+    {
+        return;
+    }
+
+    if (enabled == 0)
+    {
+        if (_codexComposerRegion && _codexComposerRegion->token == token)
+        {
+            _codexComposerRegion.reset();
+        }
+        return;
+    }
+
+    if (token == 0 || columns == 0 || rows == 0 || width == 0 || height == 0 ||
+        x > columns || y > rows || width > columns - x || height > rows - y ||
+        cursorX >= columns || cursorY >= rows ||
+        cursorX < x || cursorX > x + width || cursorY < y || cursorY >= y + height)
+    {
+        return;
+    }
+
+    const auto viewport = _GetMutableViewport();
+    const auto viewportSize = viewport.Dimensions();
+    const auto cursor = GetCursorPosition() - viewport.Origin();
+    if (columns != static_cast<uint64_t>(viewportSize.width) ||
+        rows != static_cast<uint64_t>(viewportSize.height) ||
+        cursorX != static_cast<uint64_t>(cursor.x) ||
+        cursorY != static_cast<uint64_t>(cursor.y))
+    {
+        return;
+    }
+
+    const auto& buffer = _activeBuffer();
+    _codexComposerRegion = CodexComposerRegion{
+        .token = token,
+        .generation = generation,
+        .mutationId = buffer.GetLastMutationId(),
+        .viewportSize = viewportSize,
+        .area = til::rect{
+            til::point{ gsl::narrow_cast<til::CoordType>(x), gsl::narrow_cast<til::CoordType>(y) },
+            til::size{ gsl::narrow_cast<til::CoordType>(width), gsl::narrow_cast<til::CoordType>(height) } },
+        .cursor = cursor,
+        .isMainBuffer = !_inAltBuffer(),
+    };
+}
+
+std::optional<Terminal::CodexComposerGestureIdentity> Terminal::GetCodexComposerGestureAt(const til::point viewportPos) const noexcept
+{
+    _assertLocked();
+    const auto& region = _codexComposerRegion;
+    const auto cursor = GetCursorPosition() - _GetMutableViewport().Origin();
+    if (!region ||
+        _scrollOffset != 0 ||
+        region->isMainBuffer == _inAltBuffer() ||
+        region->viewportSize != _GetMutableViewport().Dimensions() ||
+        region->cursor != cursor ||
+        region->mutationId != _activeBuffer().GetLastMutationId() ||
+        !region->area.contains(viewportPos))
+    {
+        return std::nullopt;
+    }
+    return CodexComposerGestureIdentity{
+        .token = region->token,
+        .viewportSize = region->viewportSize,
+        .area = region->area,
+        .isMainBuffer = region->isMainBuffer,
+    };
+}
+
+bool Terminal::IsCodexComposerGestureValid(const CodexComposerGestureIdentity& identity) const noexcept
+{
+    _assertLocked();
+    const auto& region = _codexComposerRegion;
+    return region &&
+           _scrollOffset == 0 &&
+           region->token == identity.token &&
+           region->viewportSize == identity.viewportSize &&
+           region->area == identity.area &&
+           region->isMainBuffer == identity.isMainBuffer &&
+           region->isMainBuffer != _inAltBuffer() &&
+           region->viewportSize == _GetMutableViewport().Dimensions();
+}
