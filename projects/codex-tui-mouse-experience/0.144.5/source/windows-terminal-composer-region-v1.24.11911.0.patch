+    bool ControlInteractivity::TryBeginCodexComposerPointer(
+        const uint32_t pointerId,
+        const Windows::Devices::Input::PointerDeviceType pointerDeviceType,
+        const Control::MouseButtonState buttonState,
+        const unsigned int pointerUpdateKind,
+        const ::Microsoft::Terminal::Core::ControlKeyStates modifiers,
+        const Core::Point pixelPosition)
+    {
+        if (pointerDeviceType != Windows::Devices::Input::PointerDeviceType::Mouse ||
+            _codexComposerPointerGesture)
+        {
+            return false;
+        }
+
+        if (pointerUpdateKind != WM_LBUTTONDOWN ||
+            !WI_IsFlagSet(buttonState, MouseButtonState::IsLeftButtonDown) ||
+            WI_IsFlagSet(buttonState, MouseButtonState::IsMiddleButtonDown) ||
+            WI_IsFlagSet(buttonState, MouseButtonState::IsRightButtonDown) ||
+            _core->IsInReadOnlyMode())
+        {
+            return false;
+        }
+
+        const auto terminalPosition = _getTerminalPosition(til::point{ pixelPosition }, false);
+        const auto identity = _core->TryBeginCodexComposerGesture(terminalPosition);
+        if (!identity)
+        {
+            return false;
+        }
+
+        _codexComposerPointerGesture = CodexComposerPointerGesture{
+            .identity = *identity,
+            .pointerId = pointerId,
+            .pointerDeviceType = pointerDeviceType,
+            .lastPosition = terminalPosition,
+            .modifiers = modifiers,
+        };
+        _sendCodexComposerPointer(terminalPosition, modifiers, false, false);
+        return true;
+    }
+
+    bool ControlInteractivity::TryMoveCodexComposerPointer(
+        const uint32_t pointerId,
+        const Windows::Devices::Input::PointerDeviceType pointerDeviceType,
+        const Control::MouseButtonState buttonState,
+        const ::Microsoft::Terminal::Core::ControlKeyStates modifiers,
+        const Core::Point pixelPosition)
+    {
+        if (!_codexComposerPointerGesture ||
+            _codexComposerPointerGesture->pointerId != pointerId ||
+            _codexComposerPointerGesture->pointerDeviceType != pointerDeviceType)
+        {
+            return false;
+        }
+
+        const auto terminalPosition = _getTerminalPosition(til::point{ pixelPosition }, false);
+        const auto clamped = _core->ClampToViewport(terminalPosition);
+        _codexComposerPointerGesture->lastPosition = clamped;
+        _codexComposerPointerGesture->modifiers = modifiers;
+        if (!_codexComposerPointerGesture->ended &&
+            !_core->IsCodexComposerGestureValid(_codexComposerPointerGesture->identity))
+        {
+            _sendCodexComposerPointer(clamped, modifiers, true, false);
+            _codexComposerPointerGesture->ended = true;
+        }
+        else if (!_codexComposerPointerGesture->ended &&
+                 WI_IsFlagSet(buttonState, MouseButtonState::IsLeftButtonDown))
+        {
+            _sendCodexComposerPointer(clamped, modifiers, false, true);
+        }
+        else if (!_codexComposerPointerGesture->ended)
+        {
+            _sendCodexComposerPointer(clamped, modifiers, true, false);
+            _codexComposerPointerGesture->ended = true;
+        }
+        return true;
+    }
+
+    bool ControlInteractivity::TryReleaseCodexComposerPointer(
+        const uint32_t pointerId,
+        const Windows::Devices::Input::PointerDeviceType pointerDeviceType,
+        const Control::MouseButtonState /*buttonState*/,
+        const unsigned int pointerUpdateKind,
+        const ::Microsoft::Terminal::Core::ControlKeyStates modifiers,
+        const Core::Point pixelPosition)
+    {
+        if (!_codexComposerPointerGesture ||
+            _codexComposerPointerGesture->pointerId != pointerId ||
+            _codexComposerPointerGesture->pointerDeviceType != pointerDeviceType ||
+            pointerUpdateKind != WM_LBUTTONUP)
+        {
+            return false;
+        }
+
+        const auto terminalPosition = _getTerminalPosition(til::point{ pixelPosition }, false);
+        const auto clamped = _core->ClampToViewport(terminalPosition);
+        if (!_codexComposerPointerGesture->ended)
+        {
+            _sendCodexComposerPointer(clamped, modifiers, true, false);
+        }
+        _codexComposerPointerGesture.reset();
+        return true;
+    }
+
+    bool ControlInteractivity::TryCancelCodexComposerPointer(
+        const uint32_t pointerId,
+        const Windows::Devices::Input::PointerDeviceType pointerDeviceType)
+    {
+        if (!_codexComposerPointerGesture ||
+            _codexComposerPointerGesture->pointerId != pointerId ||
+            _codexComposerPointerGesture->pointerDeviceType != pointerDeviceType)
+        {
+            return false;
+        }
+
+        CancelCodexComposerPointer();
+        return true;
+    }
