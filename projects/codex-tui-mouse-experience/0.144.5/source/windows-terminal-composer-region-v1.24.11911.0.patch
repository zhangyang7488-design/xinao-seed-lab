+    bool ControlInteractivity::IsCodexComposerPointerActive() const noexcept
+    {
+        return _codexComposerPointerGesture.has_value();
+    }
+
+    void ControlInteractivity::CancelCodexComposerPointer()
+    {
+        if (const auto gesture = std::exchange(_codexComposerPointerGesture, std::nullopt);
+            gesture && !gesture->ended)
+        {
+            _sendCodexComposerPointer(gesture->lastPosition, gesture->modifiers, true, false);
+        }
+    }
