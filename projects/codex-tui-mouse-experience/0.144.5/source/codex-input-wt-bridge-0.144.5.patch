+                let mut state = self.draft.textarea_state.borrow_mut();
+                let changed = self.draft.textarea.extend_selection_from_mouse_drag(
+                    anchor,
+                    textarea_rect,
+                    &mut state,
+                    event.column,
+                    event.row,
+                );
+                drop(state);
+                if changed {
+                    self.sync_popups();
+                }
+                changed
+            }
+            _ => false,
+        }
+    }
