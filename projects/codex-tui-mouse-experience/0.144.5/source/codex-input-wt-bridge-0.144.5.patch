+    /// Handle click-to-position and left-button drag selection in the rendered textarea.
+    pub(crate) fn handle_mouse_event(&mut self, event: MouseEvent) -> bool {
+        if matches!(event.kind, MouseEventKind::Up(MouseButton::Left)) {
+            return self.mouse_selection_anchor.take().is_some();
+        }
+        if !self.has_focus || !self.draft.input_enabled || self.history_search.is_some() {
+            self.mouse_selection_anchor = None;
+            return false;
+        }
+        let Some(textarea_rect) = self.last_textarea_rect.get() else {
+            self.mouse_selection_anchor = None;
+            return false;
+        };
+
+        match event.kind {
+            MouseEventKind::Down(MouseButton::Left) => {
+                if !Self::textarea_mouse_area(textarea_rect)
+                    .contains(Position::new(event.column, event.row))
+                {
+                    self.mouse_selection_anchor = None;
+                    return false;
+                }
+
+                let state = *self.draft.textarea_state.borrow();
+                let Some(mut target) = self.draft.textarea.cursor_from_screen_position(
+                    textarea_rect,
+                    state,
+                    event.column,
+                    event.row,
+                ) else {
+                    self.mouse_selection_anchor = None;
+                    return false;
+                };
+                let original_cursor = self.draft.textarea.cursor();
+                let original_len = self.draft.textarea.text().len();
+                if let Some(pasted) = self.draft.paste_burst.flush_before_modified_input() {
+                    self.handle_paste(pasted);
+                    let inserted_len = self
+                        .draft
+                        .textarea
+                        .text()
+                        .len()
+                        .saturating_sub(original_len);
+                    if target >= original_cursor {
+                        target = target.saturating_add(inserted_len);
+                    }
+                }
+                self.draft.paste_burst.clear_window_after_non_char();
+
+                self.attachments.clear_remote_image_selection();
+                let cursor_changed = self.draft.textarea.set_cursor_from_mouse_target(target);
+                self.mouse_selection_anchor = (!self.draft.textarea.is_vim_normal_mode())
+                    .then_some(self.draft.textarea.cursor());
+                if cursor_changed {
+                    self.sync_popups();
+                }
+                true
+            }
+            MouseEventKind::Drag(MouseButton::Left) => {
+                let Some(anchor) = self.mouse_selection_anchor else {
+                    return false;
+                };
+                if textarea_rect.is_empty() {
+                    return false;
