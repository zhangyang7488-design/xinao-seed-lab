diff --git a/codex-rs/tui/src/windows_composer_mouse.rs b/codex-rs/tui/src/windows_composer_mouse.rs
new file mode 100644
index 0000000000000000000000000000000000000000..fd125ffcdc4b043107f3e7e28737650b54b5b1e4
--- /dev/null
+++ b/codex-rs/tui/src/windows_composer_mouse.rs
@@ -0,0 +1,247 @@
+//! Windows Terminal composer-region layout publisher.
+//!
+//! Layout travels in the same ordered output stream as the rendered frame. The paired Terminal
+//! build owns pointer capture and injects standard SGR mouse records only for gestures whose press
+//! began inside this region. A process-owned named event makes stale layouts fail closed after a
+//! crash without adding a second data channel.
+
+use std::ptr;
+
+use rand::random;
+use ratatui::layout::Position;
+use ratatui::layout::Rect;
+use windows_sys::Win32::Foundation::CloseHandle;
+use windows_sys::Win32::Foundation::HANDLE;
+use windows_sys::Win32::System::Threading::CreateEventW;
+
+const OSC_ACTION: &str = "CodexComposer";
+const PROTOCOL_VERSION: u8 = 1;
+
+#[derive(Clone, Copy, Debug, Default, PartialEq, Eq)]
+struct LayoutSnapshot {
+    generation: u64,
+    terminal_width: u16,
+    terminal_height: u16,
+    textarea: Option<Rect>,
+    cursor: Option<Position>,
+}
+
+pub(crate) struct ComposerMouseSurface {
+    liveness: HANDLE,
+    token: u64,
+    layout: LayoutSnapshot,
+}
+
+impl ComposerMouseSurface {
+    pub(crate) fn start_if_enabled() -> Option<Self> {
+        if !crate::tui::composer_host_mouse_enabled() {
+            return None;
+        }
+        let session = normalize_session(&std::env::var("WT_SESSION").ok()?)?;
+        let token = loop {
+            let candidate = random::<u64>();
+            if candidate != 0 {
+                break candidate;
+            }
+        };
+        let event_name = format!(r"Local\Xinao.CodexComposer.v1.{session}.{token:016x}");
+        let wide_name: Vec<u16> = event_name.encode_utf16().chain([0]).collect();
+        let liveness = unsafe { CreateEventW(ptr::null(), 1, 0, wide_name.as_ptr()) };
+        if liveness == 0 {
+            return None;
+        }
+        Some(Self {
+            liveness,
+            token,
+            layout: LayoutSnapshot::default(),
+        })
+    }
+
+    pub(crate) fn update(
+        &mut self,
+        terminal_width: u16,
+        terminal_height: u16,
+        textarea: Option<Rect>,
+        cursor: Option<Position>,
+    ) -> Option<String> {
+        let (textarea, cursor) = valid_layout(terminal_width, terminal_height, textarea, cursor);
+        self.layout = LayoutSnapshot {
+            generation: self.layout.generation.wrapping_add(1),
+            terminal_width,
+            terminal_height,
+            textarea,
+            cursor,
+        };
+        // Publish after every complete frame. Windows Terminal binds the declaration to its
+        // current buffer mutation stamp, so a later write cannot leave a stale hit target alive.
+        Some(encode_layout(self.token, self.layout))
+    }
+
+    pub(crate) fn suspend(&mut self) -> Option<String> {
+        self.layout.textarea?;
+        self.layout.generation = self.layout.generation.wrapping_add(1);
+        self.layout.textarea = None;
+        self.layout.cursor = None;
+        Some(encode_layout(self.token, self.layout))
+    }
+}
+
+impl Drop for ComposerMouseSurface {
+    fn drop(&mut self) {
+        if self.liveness != 0 {
+            unsafe {
+                CloseHandle(self.liveness);
+            }
+            self.liveness = 0;
+        }
+    }
+}
+
+fn normalize_session(session: &str) -> Option<String> {
+    let session = session.trim_matches(['{', '}']);
+    let valid = session.len() == 36
+        && session
+            .bytes()
+            .enumerate()
+            .all(|(index, byte)| match index {
+                8 | 13 | 18 | 23 => byte == b'-',
+                _ => byte.is_ascii_hexdigit(),
+            });
+    valid.then(|| session.to_ascii_lowercase())
+}
+
+fn valid_layout(
+    terminal_width: u16,
+    terminal_height: u16,
+    textarea: Option<Rect>,
+    cursor: Option<Position>,
+) -> (Option<Rect>, Option<Position>) {
+    let textarea = textarea.filter(|area| {
+        terminal_width > 0
+            && terminal_height > 0
+            && !area.is_empty()
+            && area.right() <= terminal_width
+            && area.bottom() <= terminal_height
+    });
+    let cursor = cursor.filter(|cursor| {
+        let belongs_to_textarea = textarea.is_some_and(|area| {
+            area.contains(*cursor)
+                || (cursor.x == area.right() && cursor.y >= area.y && cursor.y < area.bottom())
+        });
+        cursor.x < terminal_width && cursor.y < terminal_height && belongs_to_textarea
+    });
+    if cursor.is_some() {
+        (textarea, cursor)
+    } else {
+        (None, None)
+    }
+}
+
+fn encode_layout(token: u64, layout: LayoutSnapshot) -> String {
+    let (enabled, x, y, width, height, cursor_x, cursor_y) = layout
+        .textarea
+        .zip(layout.cursor)
+        .map_or((0, 0, 0, 0, 0, 0, 0), |(area, cursor)| {
+            (
+                1,
+                area.x,
+                area.y,
+                area.width,
+                area.height,
+                cursor.x,
+                cursor.y,
+            )
+        });
+    format!(
+        "\x1b]9001;{OSC_ACTION};{PROTOCOL_VERSION};{token:016x};{};{};{};{enabled};{x};{y};{width};{height};{cursor_x};{cursor_y}\x07",
+        layout.generation, layout.terminal_width, layout.terminal_height
+    )
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn session_identity_accepts_only_guid_shape() {
+        assert_eq!(
+            normalize_session("{01234567-89AB-CDEF-0123-456789ABCDEF}"),
+            Some("01234567-89ab-cdef-0123-456789abcdef".to_string())
+        );
+        assert_eq!(normalize_session("..\\spoof"), None);
+        assert_eq!(normalize_session("not-a-session"), None);
+    }
+
+    #[test]
+    fn layout_action_is_bounded_and_ordered() {
+        let layout = LayoutSnapshot {
+            generation: 7,
+            terminal_width: 120,
+            terminal_height: 40,
+            textarea: Some(Rect::new(2, 31, 116, 7)),
+            cursor: Some(Position::new(12, 34)),
+        };
+        assert_eq!(
+            encode_layout(0x1234, layout),
+            "\x1b]9001;CodexComposer;1;0000000000001234;7;120;40;1;2;31;116;7;12;34\x07"
+        );
+    }
+
+    #[test]
+    fn invalid_or_empty_textarea_fails_closed() {
+        assert_eq!(
+            valid_layout(
+                80,
+                24,
+                Some(Rect::new(79, 20, 2, 1)),
+                Some(Position::new(79, 20)),
+            ),
+            (None, None)
+        );
+        assert_eq!(
+            valid_layout(
+                80,
+                24,
+                Some(Rect::new(2, 20, 0, 1)),
+                Some(Position::new(2, 20)),
+            ),
+            (None, None)
+        );
+        assert_eq!(
+            valid_layout(
+                80,
+                24,
+                Some(Rect::new(2, 20, 10, 2)),
+                Some(Position::new(1, 20)),
+            ),
+            (None, None)
+        );
+    }
+
+    #[test]
+    fn cursor_in_reserved_cell_after_exact_width_line_is_valid() {
+        let area = Rect::new(2, 20, 10, 2);
+        assert_eq!(
+            valid_layout(80, 24, Some(area), Some(Position::new(area.right(), 20))),
+            (Some(area), Some(Position::new(area.right(), 20)))
+        );
+    }
+
+    #[test]
+    fn disabled_action_clears_every_coordinate() {
+        let action = encode_layout(
+            9,
+            LayoutSnapshot {
+                generation: 3,
+                terminal_width: 80,
+                terminal_height: 24,
+                textarea: None,
+                cursor: None,
+            },
+        );
+        assert_eq!(
+            action,
+            "\x1b]9001;CodexComposer;1;0000000000000009;3;80;24;0;0;0;0;0;0;0\x07"
+        );
+    }
+}
