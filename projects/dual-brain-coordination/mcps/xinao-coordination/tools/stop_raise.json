  "inputSchema": {
    "properties": {
      "reason": {
        "title": "Reason",
        "type": "string"
      },
      "scope": {
        "default": "global",
        "title": "Scope",
        "type": "string"
      },
      "cancel_active_tasks": {
        "default": true,
        "title": "Cancel Active Tasks",
        "type": "boolean"
      },
      "idempotency_key": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Idempotency Key"
      }
    },
    "required": [
      "reason"
    ],
    "title": "stop_raiseArguments",
    "type": "object"
  }
}