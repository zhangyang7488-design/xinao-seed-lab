{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xinao.local/schemas/execution_attempt_receipt.v1.schema.json",
  "title": "Xinao provider-neutral execution attempt receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_sha256",
    "consumer_id",
    "logical_operation_id",
    "work_key",
    "attempt",
    "observed",
    "terminal_state",
    "stop_reason",
    "output",
    "invocations",
    "usage",
    "lineage",
    "provider_contract_version",
    "provider_evidence_ref",
    "provider_evidence_sha256",
    "provider_evidence_valid",
    "replayed"
  ],
  "properties": {
    "schema_version": {
      "const": "xinao.execution.attempt_receipt.v1"
    },
    "contract_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "consumer_id": {
      "type": "string",
      "minLength": 1
    },
    "logical_operation_id": {
      "type": "string",
      "minLength": 1
    },
    "work_key": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "profile_ref",
        "model_id",
        "transport_id",
        "capability_binding_sha256",
        "rules_sha256",
        "runtime_version",
        "execution_location",
        "executor_id"
      ],
      "properties": {
        "provider_id": {
          "type": "string",
          "minLength": 1
        },
        "profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "transport_id": {
          "type": "string",
          "minLength": 1
        },
        "capability_binding_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "rules_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "runtime_version": {
          "type": "string",
          "minLength": 1
        },
        "execution_location": {
          "type": "string",
          "minLength": 1
        },
        "executor_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "terminal_state": {
      "enum": [
        "completed",
        "failed",
        "cancelled",
        "timed_out"
      ]
    },
    "stop_reason": {
      "type": "string"
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "content_sha256",
        "chars",
        "schema_sha256",
        "schema_valid",
        "markers_ok",
        "substantive"
      ],
      "properties": {
        "format": {
          "type": "string",
          "minLength": 1
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "chars": {
          "type": "integer",
          "minimum": 0
        },
        "schema_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "schema_valid": {
          "type": "boolean"
        },
        "markers_ok": {
          "type": "boolean"
        },
        "substantive": {
          "type": "boolean"
        }
      }
    },
    "invocations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "invocation",
          "state",
          "observed_model",
          "stop_reason",
          "output_sha256",
          "output_chars",
          "total_tokens"
        ],
        "properties": {
          "invocation": {
            "type": "integer",
            "minimum": 1
          },
          "state": {
            "enum": [
              "accepted",
              "rejected",
              "failed",
              "cancelled",
              "timed_out"
            ]
          },
          "observed_model": {
            "type": "string",
            "minLength": 1
          },
          "stop_reason": {
            "type": "string"
          },
          "output_sha256": {
            "$ref": "#/$defs/sha256"
          },
          "output_chars": {
            "type": "integer",
            "minimum": 0
          },
          "total_tokens": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invocation_count",
        "total_tokens",
        "accepted_tokens",
        "cancelled_tokens",
        "failed_tokens"
      ],
      "properties": {
        "invocation_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cancelled_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "failed_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_id",
        "lane_id",
        "parent_operation_id",
        "correlation_id",
        "session_id"
      ],
      "properties": {
        "workflow_id": {
          "type": "string"
        },
        "lane_id": {
          "type": "string"
        },
        "parent_operation_id": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      }
    },
    "provider_contract_version": {
      "type": "string",
      "minLength": 1
    },
    "provider_evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "provider_evidence_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "provider_evidence_valid": {
      "type": "boolean"
    },
    "replayed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
