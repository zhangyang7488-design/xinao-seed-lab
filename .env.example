# XINAO 333 · compose 环境变量模板
# 复制为 .env 后填入真实密钥（.env 已在 .gitignore，勿提交）
#
#   copy .env.example .env
#   编辑 .env → docker compose up -d moxing-wangguan houtai-gongren --force-recreate

# 千问云（DashScope）— 默认工人草稿
DASHSCOPE_API_KEY=

# DeepSeek 云 — V4 Pro 验收节点
DEEPSEEK_API_KEY=

# LiteLLM 网关 master key（本地默认即可）
LITELLM_MASTER_KEY=sk-xinao-thin-glue-local