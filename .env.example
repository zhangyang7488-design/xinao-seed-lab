# XINAO 333 · compose 环境变量模板
# 复制为 .env 后填入真实密钥（.env 已在 .gitignore，勿提交）
#
#   copy .env.example .env
#   编辑 .env → docker compose up -d moxing-wangguan houtai-gongren --force-recreate

# 千问云（DashScope）— 默认工人草稿
DASHSCOPE_API_KEY=

# DeepSeek 云 — V4 Pro 验收节点
DEEPSEEK_API_KEY=

# LiteLLM 网关 master key（本地默认即可）
LITELLM_MASTER_KEY=sk-xinao-thin-glue-local

# Langfuse 自托管（compose: keguan-zhuiji UI :3100；容器内用 http://keguan-zhuiji:3000）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://127.0.0.1:3100
LANGFUSE_NEXTAUTH_URL=http://127.0.0.1:3100
LANGFUSE_INIT_ORG_NAME=XINAO
LANGFUSE_INIT_PROJECT_NAME=integrated-bus
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=admin@xinao.local
LANGFUSE_INIT_USER_PASSWORD=xinao-langfuse-local
LANGFUSE_POSTGRES_PASSWORD=langfuse
NEXTAUTH_SECRET=
SALT=
ENCRYPTION_KEY=
REDIS_AUTH=
CLICKHOUSE_PASSWORD=
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=

# SearXNG 自托管（waiwang-sousuo :8888；容器内 http://waiwang-sousuo:8080）
XINAO_SEARXNG_BASE_URL=http://127.0.0.1:8888
XINAO_SEARXNG_COMPOSE=1
# Exa 动态第三层（有 key 时 SearXNG/DDGS 不足或 heal/难度触发）
EXA_API_KEY=
XINAO_EXA_SEARCH_MODE=auto